/* ═══ TOAST ═══ */
#toast{position:fixed;bottom:60px;left:50%;transform:translateX(-50%);background:var(--card);border:1px solid var(--a2);color:var(--a2);font-family:'Share Tech Mono',monospace;font-size:11px;padding:8px 20px;letter-spacing:2px;z-index:99999;opacity:0;transition:opacity 0.3s;pointer-events:none;white-space:nowrap;}
