.pcnt{flex:1;display:none;flex-direction:column;padding:16px;gap:12px;overflow-y:auto;}
.pcnt.active{display:flex;}
.purlbar{display:flex;gap:8px;}
.purlinp{flex:1;background:var(--card);border:1px solid var(--border);color:var(--text);font-family:'Share Tech Mono',monospace;font-size:12px;padding:9px 14px;outline:none;}
