const CORRECT_PW = '1234';
function checkPW() {
  const val = document.getElementById('pw-input').value;
  const inp = document.getElementById('pw-input');
  const err = document.getElementById('pw-err');
  if (val === CORRECT_PW) {
    const screen = document.getElementById('pw-screen');
    screen.classList.add('hidden');
    setTimeout(() => screen.remove(), 600);
    err.textContent = '';
  } else {
    err.textContent = '✕ INCORRECT CODE';
    inp.classList.add('pw-wrong');
    inp.value = '';
    setTimeout(() => inp.classList.remove('pw-wrong'), 500);
  }
}
// Allow pressing Enter on password screen
document.getElementById('pw-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') checkPW();
});
//  Drive files are single-file HTML zips.
//  We fetch the raw download, get the HTML text,
//  open about:blank and write it in directly.
//  Flash: fetch as ArrayBuffer → blob URL → Ruffle.
//  CDN: same fetch→write approach, no Drive redirect.
// ══════════════════════════════════════════

function getDriveId(url) {
  const m = url.match(/\/file\/d\/([a-zA-Z0-9_-]+)/);
  return m ? m[1] : null;
}

function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

// The minimal close-bar window shell
function shellHTML(name, inner) {
  return `<!DOCTYPE html><html><head><title>${esc(name)}</title>
<style>*{margin:0;padding:0;box-sizing:border-box}body{background:#000;display:flex;flex-direction:column;height:100vh;overflow:hidden;font-family:monospace}
#_b{background:#111;border-bottom:1px solid #333;padding:6px 14px;display:flex;align-items:center;flex-shrink:0}
#_b span{color:#e63946;font-weight:bold;flex:1;font-size:13px}
#_b button{background:#e63946;border:none;color:#fff;font-size:11px;padding:4px 12px;cursor:pointer;border-radius:4px}
#_c{flex:1;display:flex;position:relative}</style></head><body>
<div id="_b"><span>▶ ${esc(name)}</span><button onclick="window.close()">✕ CLOSE</button></div>
<div id="_c">${inner}</div></body></html>`;
}

function openGame(url, name, type) {
  // ── Built-in Snake ────────────────────────────────────
  if (url === '__snake__') { launchSnake(); return; }
  const isCDN = url.includes('jsdelivr.net') || url.includes('rawcdn.githack') || url.includes('raw.githubusercontent.com');
  if (isCDN) {
    showToast('Loading ' + name + '…');
    if (url.endsWith('.swf')) {
      // Flash via CDN → fetch binary → Ruffle blob
      fetch(url)
        .then(r => { if (!r.ok) throw new Error(r.status); return r.arrayBuffer(); })
        .then(buf => launchRuffle(name, buf))
        .catch(() => { showToast('Failed — opening directly'); window.open(url, '_blank'); });
    } else {
      // HTML via CDN → fetch text → about:blank
      fetch(url)
        .then(r => { if (!r.ok) throw new Error(r.status); return r.text(); })
        .then(html => writeBlank(name, html))
        .catch(() => { showToast('Failed — opening directly'); window.open(url, '_blank'); });
    }
    return;
  }

  // ── Online games (not Drive) ─────────────────────────
  if (!url.includes('drive.google.com')) {
    const w = window.open('about:blank', '_blank');
    if (!w) { alert('Please allow popups to play games!'); return; }
    w.document.open();
    w.document.write(shellHTML(name, `<iframe src="${url}" style="position:absolute;inset:0;width:100%;height:100%;border:none;" allowfullscreen allow="fullscreen *"></iframe>`));
    w.document.close();
    return;
  }

  // ── Google Drive ─────────────────────────────────────
  const id = getDriveId(url);
  if (!id) { window.open(url, '_blank'); return; }

  // Direct download URL — Google will serve the file content
  const dlURL = `https://drive.google.com/uc?export=download&id=${id}&confirm=t`;
  showToast('Loading ' + name + '… (allow popups!)');

  if (type === 'flash') {
    // Fetch SWF binary → Ruffle in about:blank
    fetch(dlURL)
      .then(r => { if (!r.ok) throw new Error(r.status); return r.arrayBuffer(); })
      .then(buf => launchRuffle(name, buf))
      .catch(err => {
        console.warn('Drive SWF fetch failed:', err);
        showToast('Using Drive preview…');
        openDrivePreview(id, name);
      });
  } else {
    // Fetch HTML text → write into about:blank
    fetch(dlURL)
      .then(r => { if (!r.ok) throw new Error(r.status); return r.text(); })
      .then(html => {
        // Check if Drive returned a virus/download warning page instead of the game
        if (html.includes('Google Drive - Virus scan warning') || html.includes('confirm=') && html.includes('<form')) {
          // Try to extract the real download link from the warning page
          const m = html.match(/action="([^"]*uc\?[^"]*)"/);
          if (m) {
            const realURL = m[1].replace(/&amp;/g, '&');
            return fetch(realURL).then(r2 => r2.text()).then(html2 => writeBlank(name, html2));
          }
          // Fallback to preview
          showToast('File too large for direct load — using preview');
          openDrivePreview(id, name);
        } else {
          writeBlank(name, html);
        }
      })
      .catch(err => {
        console.warn('Drive HTML fetch failed:', err);
        showToast('Using Drive preview…');
        openDrivePreview(id, name);
      });
  }
}

function writeBlank(name, html) {
  const w = window.open('about:blank', '_blank');
  if (!w) { alert('Please allow popups to play games!'); return; }
  w.document.open();
  w.document.write(html);
  w.document.close();
  try { w.document.title = name; } catch(e) {}
  showToast(name + ' launched!');
}

function launchRuffle(name, arrayBuffer) {
  const blob = new Blob([arrayBuffer], { type: 'application/x-shockwave-flash' });
  const swfURL = URL.createObjectURL(blob);
  const w = window.open('about:blank', '_blank');
  if (!w) { alert('Please allow popups!'); return; }
  w.document.open();
  w.document.write(`<!DOCTYPE html><html><head><title>${esc(name)}</title>
<script src="https://unpkg.com/@ruffle-rs/ruffle"><\/script>
<style>*{margin:0;padding:0;box-sizing:border-box}body{background:#000;display:flex;flex-direction:column;height:100vh;overflow:hidden;font-family:monospace}
#_b{background:#111;border-bottom:1px solid #333;padding:6px 14px;display:flex;align-items:center;flex-shrink:0}
#_b span{color:#e63946;font-weight:bold;flex:1;font-size:13px}
#_b button{background:#e63946;border:none;color:#fff;font-size:11px;padding:4px 12px;cursor:pointer;border-radius:4px}
#_s{flex:1;display:flex}</style></head><body>
<div id="_b"><span>▶ ${esc(name)}</span><button onclick="window.close()">✕ CLOSE</button></div>
<div id="_s"></div>
<script>
window.addEventListener('load', function() {
  var ruffle = window.RufflePlayer.newest();
  var player = ruffle.createPlayer();
  player.style.width = '100%';
  player.style.height = '100%';
  player.style.flex = '1';
  document.getElementById('_s').appendChild(player);
  player.load('${swfURL}');
});
<\/script></body></html>`);
  w.document.close();
  showToast(name + ' launched!');
}

function openDrivePreview(id, name) {
  const w = window.open('about:blank', '_blank');
  if (!w) { window.open(`https://drive.google.com/file/d/${id}/preview`, '_blank'); return; }
  w.document.open();
  w.document.write(shellHTML(name, `<iframe src="https://drive.google.com/file/d/${id}/preview" style="position:absolute;inset:0;width:100%;height:100%;border:none;" allowfullscreen></iframe>`));
  w.document.close();
}

