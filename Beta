function cloakBlank() {
  const w = window.open('about:blank', '_blank');
  if (!w) { alert('Allow popups!'); return; }
  w.document.open(); w.document.write(document.documentElement.outerHTML); w.document.close();
  w.document.title = 'Google Classroom';
  window.location.href = 'https://classroom.google.com';
}
function cloakBlob() {
  const blob = new Blob([document.documentElement.outerHTML], {type:'text/html'});
  const burl = URL.createObjectURL(blob);
  const w = window.open(burl, '_blank');
  if (!w) { alert('Allow popups!'); return; }
  setTimeout(() => URL.revokeObjectURL(burl), 10000);
  window.location.href = 'https://classroom.google.com';
}

