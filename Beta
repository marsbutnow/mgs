function spawnFood(){
  do{ food={x:Math.floor(Math.random()*COLS),y:Math.floor(Math.random()*ROWS)}; }
  while(snake.some(s=>s.x===food.x&&s.y===food.y));
}

function tick(){
  if(!running||paused)return;
  dir=nextDir;
  const head={x:snake[0].x+dir.x,y:snake[0].y+dir.y};
  // wall collision
  if(head.x<0||head.x>=COLS||head.y<0||head.y>=ROWS){die();return;}
  // self collision
  if(snake.some(s=>s.x===head.x&&s.y===head.y)){die();return;}
  snake.unshift(head);
  if(head.x===food.x&&head.y===food.y){
    score++; if(score>hi)hi=score;
    document.getElementById('sc').textContent=score;
    document.getElementById('hi').textContent=hi;
    spawnFood();
  } else { snake.pop(); }
  draw();
}

function draw(){
  ctx.fillStyle='#050f05'; ctx.fillRect(0,0,canvas.width,canvas.height);
  // grid dots
  ctx.fillStyle='rgba(0,255,65,0.04)';
  for(let x=0;x<COLS;x++) for(let y=0;y<ROWS;y++) ctx.fillRect(x*SZ+9,y*SZ+9,2,2);
  // food pulse
  const pulse=0.7+0.3*Math.sin(Date.now()/200);
  ctx.fillStyle=COLORS.food;
  ctx.shadowColor=COLORS.food; ctx.shadowBlur=12*pulse;
  ctx.beginPath(); ctx.arc(food.x*SZ+SZ/2,food.y*SZ+SZ/2,SZ/2-3,0,Math.PI*2); ctx.fill();
  ctx.shadowBlur=0;
  // snake body
  snake.forEach((seg,i)=>{
    const t=i/snake.length;
    const r=Math.round(0+(0-0)*t); const g=Math.round(255+(122-255)*t); const b=Math.round(65+(32-65)*t);
    ctx.fillStyle=i===0?COLORS.head:\`rgb(\${Math.round(0+(0)*t)},\${Math.round(255-133*t)},\${Math.round(65-33*t)})\`;
    ctx.shadowColor=i===0?COLORS.head:'transparent'; ctx.shadowBlur=i===0?10:0;
    const pad=i===0?1:2;
    ctx.beginPath();
    ctx.roundRect(seg.x*SZ+pad,seg.y*SZ+pad,SZ-pad*2,SZ-pad*2,i===0?6:4);
    ctx.fill();
  });
  ctx.shadowBlur=0;
  // eyes on head
  if(snake.length>0){
    const h=snake[0]; const ex=h.x*SZ+SZ/2,ey=h.y*SZ+SZ/2;
    const ox=dir.x*4, oy=dir.y*4;
    const px=dir.y*3, py=-dir.x*3;
    ctx.fillStyle='#000';
    [[ex+ox+px,ey+oy+py],[ex+ox-px,ey+oy-py]].forEach(([ex2,ey2])=>{
      ctx.beginPath(); ctx.arc(ex2,ey2,2.5,0,Math.PI*2); ctx.fill();
      ctx.fillStyle='#fff';
      ctx.beginPath(); ctx.arc(ex2+0.8,ey2-0.8,0.8,0,Math.PI*2); ctx.fill();
      ctx.fillStyle='#000';
    });
  }
  if(paused){
    ctx.fillStyle='rgba(0,0,0,0.55)'; ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.fillStyle='#00ff41'; ctx.font='bold 18px Courier New';
    ctx.textAlign='center'; ctx.fillText('PAUSED',canvas.width/2,canvas.height/2);
  }
}

function die(){
  running=false; clearInterval(loop);
  document.getElementById('fs').textContent='Score: '+score;
  document.getElementById('over').classList.add('show');
}

function restart(){ init(); }

document.addEventListener('keydown',e=>{
  const map={ArrowUp:{x:0,y:-1},ArrowDown:{x:0,y:1},ArrowLeft:{x:-1,y:0},ArrowRight:{x:1,y:0},
             w:{x:0,y:-1},s:{x:0,y:1},a:{x:-1,y:0},d:{x:1,y:0}};
