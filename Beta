.ptabs{display:flex;gap:6px;margin-left:auto;}
.ptab{background:transparent;border:1px solid var(--border);color:var(--dim);font-family:'Share Tech Mono',monospace;font-size:9px;padding:5px 12px;cursor:pointer;letter-spacing:1px;transition:all 0.15s;}
