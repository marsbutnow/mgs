function setFilter(f, el) {
  curFilter = f;
  document.querySelectorAll('.fbtn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  renderGames();
}
function filterGames() {
  curSearch = document.getElementById('search').value.toLowerCase();
  renderGames();
}
function renderGames() {
  const grid = document.getElementById('game-grid');
  const noRes = document.getElementById('no-res');
  const filtered = GAMES.filter(g =>
    (curFilter === 'all' || g.t === curFilter) &&
    (!curSearch || g.n.toLowerCase().includes(curSearch))
  );
  document.getElementById('gcount').textContent = filtered.length;
  if (!filtered.length) { grid.innerHTML = ''; noRes.classList.add('show'); return; }
  noRes.classList.remove('show');
  grid.innerHTML = filtered.map((g, i) => {
    const safe = g.n.replace(/'/g, "\\'");
    return `<a class="gcard" href="#" onclick="event.preventDefault();openGame('${g.u.replace(/'/g,"\\'")}','${safe}','${g.t}');" style="animation-delay:${Math.min(i*0.012,0.4)}s">
  <div class="card-tip"><span class="tip-name">${g.n}</span><span style="color:var(--dim);font-size:9px;">${TL[g.t]||g.t}</span></div>
  <div class="card-body">
    <div class="card-name">${g.n}</div>
    <div class="card-tag">${TL[g.t]||g.t}</div>
  </div>
</a>`;
  }).join('');
}

