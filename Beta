window.addEventListener('load', () => {
  // Restore theme
  const savedTheme = localStorage.getItem('mgs-theme');
  if (savedTheme) {
    document.body.setAttribute('data-theme', savedTheme);
    const el = document.querySelector(`.th-opt[data-theme="${savedTheme}"]`);
    if (el) { document.querySelectorAll('.th-opt').forEach(o=>o.classList.remove('active')); el.classList.add('active'); }
  }

  loadSettings();
  renderGames();
  initPlayer();

  // Hide loader after short delay
  setTimeout(() => {
    const l = document.getElementById('loader');
    l.classList.add('hidden');
    setTimeout(() => l.remove(), 600);
  }, 1000);
});
