// ══════════════════════════════════════════
const TRACKS = [
  {title:"Stereo Madness (GD)", src:"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3"},
  {title:"Chill Lo-Fi Beats",   src:"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3"},
  {title:"Cyberpunk Vibes",     src:"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3"},
  {title:"Electronic Dreams",   src:"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-4.mp3"},
  {title:"Space Ambience",      src:"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-5.mp3"},
  {title:"Mars Station Radio",  src:"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-6.mp3"},
  {title:"Retro Wave",          src:"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-7.mp3"},
  {title:"Boss Battle Theme",   src:"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-8.mp3"},
];
let curT=0, isPlaying=false, shuffle=false, loop=false;
const audio = document.getElementById('audio-el');

function initPlayer() {
  document.getElementById('track-list').innerHTML = TRACKS.map((t,i) => `
    <div class="titem${i===curT?' playing':''}" id="ti-${i}" onclick="playTrack(${i})">
      <span style="font-family:'Share Tech Mono',monospace;font-size:9px;color:var(--dim);width:14px;">${i+1}</span>
      <div class="vbars"><div class="vb"></div><div class="vb"></div><div class="vb"></div></div>
      <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${t.title}</span>
    </div>`).join('');
  audio.src = TRACKS[curT].src;
  audio.volume = 0.7;
  audio.addEventListener('timeupdate', updProg);
  audio.addEventListener('ended', onEnd);
}
function playTrack(i) {
  curT = i; audio.src = TRACKS[i].src; audio.play(); isPlaying = true;
  document.getElementById('play-btn').textContent = '⏸';
  document.getElementById('np-title').textContent = TRACKS[i].title;
  document.querySelectorAll('.titem').forEach((el,j) => {
    el.classList.toggle('playing', j===i);
    el.querySelectorAll('.vb').forEach(b => { b.style.animation = j===i?'':'none'; b.style.height = j===i?'':'4px'; });
  });
  document.getElementById('hdr-vbars').querySelectorAll('.vb').forEach(b => b.style.animation='vba 0.6s ease-in-out infinite');
}
function togglePlay() {
  if (isPlaying) { audio.pause(); isPlaying=false; document.getElementById('play-btn').textContent='▶'; document.getElementById('hdr-vbars').querySelectorAll('.vb').forEach(b=>b.style.animation='none'); }
  else { audio.play(); isPlaying=true; document.getElementById('play-btn').textContent='⏸'; document.getElementById('hdr-vbars').querySelectorAll('.vb').forEach(b=>b.style.animation='vba 0.6s ease-in-out infinite'); }
}
function nextTrack() { playTrack(shuffle ? Math.floor(Math.random()*TRACKS.length) : (curT+1)%TRACKS.length); }
function prevTrack() { playTrack((curT-1+TRACKS.length)%TRACKS.length); }
function toggleShuffle() { shuffle=!shuffle; document.getElementById('shuf-btn').classList.toggle('act',shuffle); }
function toggleLoop() { loop=!loop; audio.loop=loop; document.getElementById('loop-btn').classList.toggle('act',loop); }
function setVol(v) { audio.volume = v; }
function updProg() {
  if (!audio.duration) return;
  const p = (audio.currentTime/audio.duration)*100;
  document.getElementById('pfill').style.width = p+'%';
  document.getElementById('time-cur').textContent = fmt(audio.currentTime);
  document.getElementById('time-dur').textContent = fmt(audio.duration);
}
function fmt(s) { const m=Math.floor(s/60); return m+':'+(Math.floor(s%60)+'').padStart(2,'0'); }
function seekTo(e) { const b=document.getElementById('pbar2'); audio.currentTime=(e.offsetX/b.offsetWidth)*audio.duration; }
function onEnd() { if (!loop) nextTrack(); }
function toggleMusic() {
  const p = document.getElementById('music-player');
  if (!p.classList.contains('open') && !p.classList.contains('mini')) p.classList.add('mini');
  else p.classList.toggle('open');
}
function toggleMusicExpand() {
  const p = document.getElementById('music-player');
  p.classList.toggle('open');
  p.classList.toggle('mini', !p.classList.contains('open'));
}

