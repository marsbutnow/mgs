<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mars Game Stash</title>
<script src="https://unpkg.com/@ruffle-rs/ruffle"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Share+Tech+Mono&family=Rajdhani:wght@300;400;600;700&family=Inter:wght@400;500;600;700&display=swap');

/* ═══ THEMES ═══ */
:root,[data-theme="mars"]{--bg:#080b14;--bg2:#0d1220;--card:#0f1627;--card-hover:#162035;--a1:#e63946;--a2:#00d4ff;--a3:#ff6b35;--text:#c8d6e5;--dim:#5a7a9a;--border:#1a2a40;--glow:rgba(0,212,255,0.15);--glow-red:rgba(230,57,70,0.2);--scan:rgba(0,0,0,0.03);}
[data-theme="neon"]{--bg:#050510;--bg2:#08081a;--card:#0a0a20;--card-hover:#10102a;--a1:#ff00ff;--a2:#00ffaa;--a3:#ffff00;--text:#e0e0ff;--dim:#5050aa;--border:#1a1a40;--glow:rgba(0,255,170,0.15);--glow-red:rgba(255,0,255,0.2);--scan:rgba(0,0,0,0.04);}
[data-theme="hacker"]{--bg:#000500;--bg2:#010801;--card:#020c02;--card-hover:#041204;--a1:#00ff41;--a2:#00cc33;--a3:#39ff14;--text:#00ff41;--dim:#006614;--border:#003300;--glow:rgba(0,255,65,0.15);--glow-red:rgba(0,255,65,0.2);--scan:rgba(0,0,0,0.06);}
[data-theme="abyss"]{--bg:#02020a;--bg2:#05050f;--card:#07071a;--card-hover:#0c0c22;--a1:#7b2fff;--a2:#ff2fff;--a3:#2fffff;--text:#c5b8ff;--dim:#4a3a80;--border:#1a1040;--glow:rgba(123,47,255,0.15);--glow-red:rgba(255,47,255,0.2);--scan:rgba(0,0,0,0.04);}
[data-theme="ember"]{--bg:#0f0600;--bg2:#160900;--card:#1a0c00;--card-hover:#241200;--a1:#ff6a00;--a2:#ffb347;--a3:#ff3300;--text:#ffe0b2;--dim:#7a4010;--border:#3a1800;--glow:rgba(255,106,0,0.15);--glow-red:rgba(255,51,0,0.2);--scan:rgba(0,0,0,0.04);}
[data-theme="ice"]{--bg:#00080f;--bg2:#000f1a;--card:#001525;--card-hover:#001e33;--a1:#00cfff;--a2:#80e8ff;--a3:#ffffff;--text:#cceeff;--dim:#336688;--border:#003355;--glow:rgba(0,207,255,0.15);--glow-red:rgba(128,232,255,0.2);--scan:rgba(0,0,0,0.03);}
[data-theme="coffee"]{--bg:#1a100a;--bg2:#221508;--card:#2a1c10;--card-hover:#362414;--a1:#c8813a;--a2:#f0c070;--a3:#e8a050;--text:#f5e6d0;--dim:#8a6040;--border:#4a2e18;--glow:rgba(240,192,112,0.15);--glow-red:rgba(200,129,58,0.2);--scan:rgba(0,0,0,0.04);}
[data-theme="chocolate"]{--bg:#0f0805;--bg2:#180d07;--card:#1f1009;--card-hover:#2a160c;--a1:#8b4513;--a2:#d2691e;--a3:#ff8c42;--text:#e8d5c4;--dim:#6b3a20;--border:#3d1a0a;--glow:rgba(210,105,30,0.15);--glow-red:rgba(139,69,19,0.2);--scan:rgba(0,0,0,0.05);}
[data-theme="rainbow"]{--bg:#0a0a0a;--bg2:#111;--card:#161616;--card-hover:#1e1e1e;--a1:#ff4466;--a2:#44ffcc;--a3:#ffdd44;--text:#fff;--dim:#666;--border:#2a2a2a;--glow:rgba(68,255,204,0.15);--glow-red:rgba(255,68,102,0.2);--scan:rgba(0,0,0,0.03);}
[data-theme="modern"]{--bg:#f0f2f5;--bg2:#ffffff;--card:#ffffff;--card-hover:#f8f9ff;--a1:#6c63ff;--a2:#4f46e5;--a3:#ec4899;--text:#1a1a2e;--dim:#8892a4;--border:#e2e8f0;--glow:rgba(79,70,229,0.18);--glow-red:rgba(236,72,153,0.15);--scan:rgba(0,0,0,0);}
/* Modern theme overrides — rounded, light, clean */
[data-theme="modern"] body{font-family:'Inter',system-ui,sans-serif;}
[data-theme="modern"] body::after{display:none;}
[data-theme="modern"] .tb{clip-path:none;border-radius:20px;font-family:'Inter',system-ui,sans-serif;}
[data-theme="modern"] #toolbar{background:rgba(255,255,255,0.85);border-bottom-color:#e2e8f0;box-shadow:0 1px 12px rgba(0,0,0,0.08);}
[data-theme="modern"] .gcard{clip-path:none;border-radius:16px;box-shadow:0 2px 12px rgba(0,0,0,0.07);}
[data-theme="modern"] .gcard:hover{box-shadow:0 8px 32px rgba(79,70,229,0.18);transform:translateY(-3px);}
[data-theme="modern"] #search{clip-path:none;border-radius:12px;background:#fff;border-color:#e2e8f0;font-family:'Inter',system-ui,sans-serif;}
[data-theme="modern"] .fbtn{border-radius:20px;}
[data-theme="modern"] .controls{background:rgba(240,242,245,0.95);}
[data-theme="modern"] .s-box{border-radius:20px;}
[data-theme="modern"] .s-inp{border-radius:10px;}
[data-theme="modern"] #theme-panel{border-radius:14px;}
[data-theme="modern"] .link-card{clip-path:none;border-radius:14px;}
[data-theme="modern"] .t-mars{color:var(--a1);text-shadow:none;}
[data-theme="modern"] .t-rest{color:var(--a2);text-shadow:none;}
[data-theme="modern"] .card-name{color:#1a1a2e;}
[data-theme="modern"] .gcard:hover .card-name{color:var(--a2);}
[data-theme="modern"] .site-title .t-icon{background:radial-gradient(circle,var(--a1) 30%,var(--a2) 100%);}
[data-theme="modern"] header{background:linear-gradient(180deg,rgba(79,70,229,0.05) 0%,transparent 100%);}
[data-theme="modern"] .hdr-sub{color:var(--dim);}
[data-theme="modern"] footer{background:#fff;border-top-color:#e2e8f0;}

/* ═══ PASSWORD SCREEN ═══ */
#pw-screen{position:fixed;inset:0;z-index:999999;background:var(--bg);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0;}
#pw-screen.hidden{opacity:0;pointer-events:none;transition:opacity 0.5s;}
.pw-box{background:var(--card);border:1px solid var(--border);padding:44px 48px;display:flex;flex-direction:column;align-items:center;gap:18px;max-width:380px;width:90%;clip-path:polygon(0 0,calc(100% - 16px) 0,100% 16px,100% 100%,16px 100%,0 calc(100% - 16px));box-shadow:0 20px 60px rgba(0,0,0,0.6);}
[data-theme="modern"] .pw-box{clip-path:none;border-radius:24px;}
.pw-logo{font-size:38px;}
.pw-title{font-family:'Orbitron',sans-serif;font-size:20px;font-weight:900;letter-spacing:4px;text-transform:uppercase;color:var(--a2);text-shadow:0 0 20px var(--glow);text-align:center;}
.pw-sub{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:3px;color:var(--dim);text-align:center;text-transform:uppercase;}
#pw-input{width:100%;background:var(--bg2);border:2px solid var(--border);color:var(--text);font-family:'Share Tech Mono',monospace;font-size:18px;padding:12px 16px;outline:none;text-align:center;letter-spacing:8px;transition:all 0.2s;clip-path:polygon(0 0,calc(100% - 6px) 0,100% 6px,100% 100%,6px 100%,0 calc(100% - 6px));}
[data-theme="modern"] #pw-input{clip-path:none;border-radius:12px;}
#pw-input:focus{border-color:var(--a2);box-shadow:0 0 0 3px var(--glow);}
#pw-input.pw-wrong{border-color:var(--a1);animation:pwShake 0.4s ease;}
#pw-enter{background:var(--a2);border:none;color:#000;font-family:'Orbitron',sans-serif;font-size:11px;font-weight:700;padding:12px 36px;cursor:pointer;letter-spacing:3px;clip-path:polygon(0 0,calc(100% - 6px) 0,100% 6px,100% 100%,6px 100%,0 calc(100% - 6px));transition:all 0.18s;}
[data-theme="modern"] #pw-enter{clip-path:none;border-radius:10px;}
#pw-enter:hover{opacity:0.86;transform:translateY(-1px);}
#pw-err{font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--a1);letter-spacing:2px;min-height:16px;text-align:center;}
@keyframes pwShake{0%,100%{transform:translateX(0)}20%{transform:translateX(-8px)}40%{transform:translateX(8px)}60%{transform:translateX(-6px)}80%{transform:translateX(6px)}}

/* ═══ TICKER ═══ */
#ticker{position:fixed;bottom:0;left:0;right:0;z-index:9960;height:28px;background:rgba(0,0,0,0.6);backdrop-filter:blur(8px);border-top:1px solid var(--border);overflow:hidden;display:flex;align-items:center;}
#ticker-inner{display:flex;align-items:center;white-space:nowrap;animation:tickerScroll 28s linear infinite;}
.tick-msg{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--a2);padding:0 60px;}
.tick-sep{color:var(--dim);font-size:10px;}
@keyframes tickerScroll{0%{transform:translateX(100vw)}100%{transform:translateX(-100%)}}
/* fade edges */
#ticker::before,#ticker::after{content:'';position:absolute;top:0;bottom:0;width:80px;z-index:1;pointer-events:none;}
#ticker::before{left:0;background:linear-gradient(90deg,rgba(0,0,0,0.7),transparent);}
#ticker::after{right:0;background:linear-gradient(270deg,rgba(0,0,0,0.7),transparent);}
[data-theme="modern"] #ticker{background:rgba(240,242,245,0.9);border-top-color:#e2e8f0;}
[data-theme="modern"] #ticker::before{background:linear-gradient(90deg,rgba(240,242,245,0.9),transparent);}
[data-theme="modern"] #ticker::after{background:linear-gradient(270deg,rgba(240,242,245,0.9),transparent);}

*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Rajdhani',sans-serif;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 80% 50% at 20% -10%,var(--glow) 0%,transparent 60%),radial-gradient(ellipse 60% 40% at 80% 110%,var(--glow-red) 0%,transparent 60%);pointer-events:none;z-index:0;}
body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,var(--scan) 2px,var(--scan) 4px);pointer-events:none;z-index:999;}

/* ═══ LOADER ═══ */
#loader{position:fixed;inset:0;background:var(--bg);z-index:99999;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:20px;transition:opacity 0.5s;}
#loader.hidden{opacity:0;pointer-events:none;}
.ld-title{font-family:'Orbitron',sans-serif;font-size:28px;font-weight:900;letter-spacing:6px;color:var(--a2);text-shadow:0 0 20px var(--glow);animation:pulse 1.5s ease-in-out infinite;}
.ld-bar-wrap{width:280px;height:3px;background:var(--border);overflow:hidden;}
.ld-bar{height:100%;background:linear-gradient(90deg,var(--a1),var(--a2));animation:ldbar 1.2s ease-in-out infinite;}
.ld-txt{font-family:'Share Tech Mono',monospace;font-size:11px;letter-spacing:3px;color:var(--dim);text-transform:uppercase;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.6}}
@keyframes ldbar{0%{width:0%;margin-left:0}50%{width:60%;margin-left:20%}100%{width:0%;margin-left:100%}}

/* ═══ TOOLBAR ═══ */
#toolbar{position:fixed;top:0;left:0;right:0;z-index:9990;display:flex;gap:6px;padding:8px 12px;flex-wrap:wrap;background:rgba(0,0,0,0.5);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);}
.tb{background:rgba(255,255,255,0.05);border:1px solid var(--border);color:var(--dim);font-family:'Share Tech Mono',monospace;font-size:10px;padding:5px 11px;cursor:pointer;letter-spacing:1.5px;text-transform:uppercase;transition:all 0.18s;clip-path:polygon(0 0,calc(100% - 5px) 0,100% 5px,100% 100%,5px 100%,0 calc(100% - 5px));}
.tb:hover,.tb.act{border-color:var(--a2);color:var(--a2);background:rgba(0,212,255,0.08);}
.tb.red{border-color:rgba(230,57,70,0.4);color:var(--a1);}
.tb.red:hover{border-color:var(--a1);background:rgba(230,57,70,0.12);}

/* ═══ THEME PANEL ═══ */
#theme-panel{position:fixed;top:46px;right:12px;z-index:9980;background:var(--card);border:1px solid var(--border);padding:14px;display:none;flex-direction:column;gap:8px;min-width:170px;box-shadow:0 8px 32px rgba(0,0,0,0.6);border-radius:4px;}
#theme-panel.open{display:flex;}
#theme-panel h4{font-family:'Orbitron',sans-serif;font-size:10px;letter-spacing:3px;color:var(--a2);margin-bottom:4px;}
.th-opt{display:flex;align-items:center;gap:8px;cursor:pointer;font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--dim);padding:5px 8px;border:1px solid transparent;transition:all 0.15s;border-radius:2px;}
.th-opt:hover,.th-opt.active{border-color:var(--border);color:var(--text);background:rgba(255,255,255,0.03);}
.th-opt.active{border-color:var(--a2);color:var(--a2);}
.th-sw{width:14px;height:14px;border-radius:50%;border:1px solid rgba(255,255,255,0.2);flex-shrink:0;}

/* ═══ HEADER ═══ */
header{position:relative;z-index:10;padding:68px 40px 20px;border-bottom:1px solid var(--border);background:linear-gradient(180deg,rgba(0,212,255,0.03) 0%,transparent 100%);}
.hdr{max-width:1500px;margin:0 auto;}
.site-title{font-family:'Orbitron',sans-serif;font-size:clamp(22px,4vw,40px);font-weight:900;letter-spacing:4px;text-transform:uppercase;line-height:1;display:flex;align-items:center;gap:14px;}
.t-icon{width:36px;height:36px;background:radial-gradient(circle,var(--a1) 30%,#4a0000 100%);border-radius:50%;box-shadow:0 0 20px var(--glow-red),inset 0 -4px 8px rgba(0,0,0,0.4);flex-shrink:0;position:relative;overflow:hidden;}
.t-icon::after{content:'';position:absolute;top:20%;left:15%;width:25%;height:15%;background:rgba(255,255,255,0.3);border-radius:50%;transform:rotate(-30deg);}
.t-mars{color:var(--a1);text-shadow:0 0 20px var(--glow-red),0 0 40px var(--glow-red);}
.t-rest{color:var(--a2);text-shadow:0 0 20px var(--glow);}
.hdr-sub{font-family:'Share Tech Mono',monospace;color:var(--dim);font-size:11px;letter-spacing:3px;margin-top:8px;text-transform:uppercase;}

/* ═══ CONTROLS ═══ */
.controls{position:sticky;top:44px;z-index:100;background:rgba(8,11,20,0.93);backdrop-filter:blur(14px);border-bottom:1px solid var(--border);padding:14px 40px;}
.ctrl-inner{max-width:1500px;margin:0 auto;display:flex;gap:12px;align-items:center;flex-wrap:wrap;}
#search{flex:1;min-width:180px;background:var(--card);border:1px solid var(--border);color:var(--text);font-family:'Share Tech Mono',monospace;font-size:13px;padding:9px 14px;outline:none;transition:border-color 0.2s,box-shadow 0.2s;clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px));}
#search::placeholder{color:var(--dim);}
#search:focus{border-color:var(--a2);box-shadow:0 0 0 1px var(--a2),0 0 12px var(--glow);}
.fbtns{display:flex;gap:6px;flex-wrap:wrap;}
.fbtn{background:transparent;border:1px solid var(--border);color:var(--dim);font-family:'Share Tech Mono',monospace;font-size:10px;padding:6px 12px;cursor:pointer;letter-spacing:1px;text-transform:uppercase;transition:all 0.18s;}
.fbtn:hover,.fbtn.active{border-color:var(--a2);color:var(--a2);background:rgba(0,212,255,0.07);}
.gcount{font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--dim);margin-left:auto;white-space:nowrap;}
.gcount span{color:var(--a2);font-weight:bold;}

/* ═══ MAIN ═══ */
main{position:relative;z-index:1;max-width:1500px;margin:0 auto;padding:24px 40px 110px;}
.sec-label{font-family:'Orbitron',sans-serif;font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--a1);margin:28px 0 14px;display:flex;align-items:center;gap:12px;}
.sec-label::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--a1),transparent);opacity:0.3;}

/* ═══ GRID ═══ */
.game-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(188px,1fr));gap:10px;}
.gcard{position:relative;background:var(--card);border:1px solid var(--border);cursor:pointer;transition:all 0.22s ease;clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,10px 100%,0 calc(100% - 10px));overflow:hidden;display:block;text-decoration:none;color:inherit;animation:cardIn 0.3s ease both;}
.gcard::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,212,255,0.04) 0%,transparent 60%);opacity:0;transition:opacity 0.22s;}
.gcard:hover{border-color:var(--a2);background:var(--card-hover);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,0.4),0 0 0 1px rgba(0,212,255,0.2),0 0 20px var(--glow);}
.gcard:hover::before{opacity:1;}
.card-body{padding:13px 13px 11px;}
.card-name{font-family:'Rajdhani',sans-serif;font-size:13px;font-weight:600;letter-spacing:0.5px;color:var(--text);line-height:1.3;transition:color 0.2s;word-break:break-word;}
.gcard:hover .card-name{color:var(--a2);}
.card-tag{display:inline-block;margin-top:5px;font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:1px;text-transform:uppercase;color:var(--dim);background:rgba(255,255,255,0.03);padding:2px 5px;border:1px solid rgba(255,255,255,0.06);}
.card-tip{position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);background:#1a2535;border:1px solid var(--a2);color:var(--text);font-family:'Share Tech Mono',monospace;font-size:10px;padding:7px 11px;white-space:nowrap;pointer-events:none;opacity:0;transition:opacity 0.12s;z-index:200;box-shadow:0 4px 16px rgba(0,0,0,0.5),0 0 8px var(--glow);}
.card-tip::after{content:'';position:absolute;top:100%;left:50%;transform:translateX(-50%);border:4px solid transparent;border-top-color:var(--a2);}
.gcard:hover .card-tip{opacity:1;}
.tip-name{color:var(--a2);font-weight:bold;display:block;margin-bottom:2px;}
.no-res{display:none;text-align:center;padding:60px 20px;color:var(--dim);font-family:'Share Tech Mono',monospace;font-size:13px;letter-spacing:2px;}
.no-res.show{display:block;}
@keyframes cardIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* ═══ SETTINGS PANEL ═══ */
#settings-panel{position:fixed;inset:0;z-index:98500;background:rgba(0,0,0,0.85);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;}
#settings-panel.open{display:flex;}
.s-box{background:var(--card);border:1px solid var(--border);min-width:340px;max-width:480px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.8);border-radius:4px;}
.s-hdr{display:flex;align-items:center;gap:10px;padding:14px 18px;border-bottom:1px solid var(--border);background:var(--bg2);}
.s-hdr span{font-family:'Orbitron',sans-serif;font-size:11px;letter-spacing:3px;color:var(--a2);flex:1;}
.s-body{padding:20px;display:flex;flex-direction:column;gap:16px;}
.s-section{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--a1);text-transform:uppercase;margin-bottom:2px;}
.s-label{font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--dim);display:block;margin-bottom:5px;}
.s-inp{width:100%;background:var(--bg2);border:1px solid var(--border);color:var(--text);font-family:'Share Tech Mono',monospace;font-size:12px;padding:8px 12px;outline:none;border-radius:2px;transition:border-color 0.2s;}
.s-inp:focus{border-color:var(--a2);}
.s-presets{display:flex;gap:5px;flex-wrap:wrap;margin-top:5px;}
.s-pre{background:transparent;border:1px solid var(--border);color:var(--dim);font-family:'Share Tech Mono',monospace;font-size:9px;padding:4px 10px;cursor:pointer;letter-spacing:1px;transition:all 0.15s;}
.s-pre:hover{border-color:var(--a2);color:var(--a2);}
.s-row{display:flex;gap:8px;}
.s-acts{display:flex;gap:8px;}
.s-btn{flex:1;padding:9px;cursor:pointer;font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;border:1px solid;transition:all 0.18s;}
.s-btn.save{background:var(--a2);color:#000;border-color:var(--a2);font-weight:700;}
.s-btn.cls{background:transparent;border-color:var(--border);color:var(--dim);}
.s-btn.cls:hover{border-color:var(--a1);color:var(--a1);}

/* ═══ HTML RUNNER ═══ */
#html-runner{position:fixed;inset:0;z-index:98000;background:var(--bg);display:none;flex-direction:column;}
#html-runner.open{display:flex;}
.rbar{display:flex;align-items:center;gap:10px;padding:8px 16px;background:var(--bg2);border-bottom:1px solid var(--border);flex-shrink:0;}
.rbar h3{font-family:'Orbitron',sans-serif;font-size:11px;letter-spacing:2px;color:var(--a2);flex:1;}
.rb{background:transparent;border:1px solid var(--border);color:var(--dim);font-family:'Share Tech Mono',monospace;font-size:10px;padding:5px 12px;cursor:pointer;letter-spacing:1px;transition:all 0.15s;}
.rb:hover{border-color:var(--a2);color:var(--a2);}
