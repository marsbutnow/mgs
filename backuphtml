// ── STATE ──
let curPage='home', curFilter='all', curSearch='', sbCollapsed=false;
let curTheme='', launchStyle='blank';
let activeRT=1;

// ── INIT ──
function initApp(){
  renderGames();
  document.getElementById('hstat-total').textContent=GAMES.length;
  startClock();
  const t=localStorage.getItem('moon-theme')||'';
  if(t){applyTheme(t);const c=document.getElementById('tc-'+t);if(c){document.querySelectorAll('.th-chip').forEach(x=>x.classList.remove('on'));c.classList.add('on');}}
}

// ── CLOCK ──
function startClock(){
  function tick(){
    const now=new Date();
    let h=now.getHours(),m=String(now.getMinutes()).padStart(2,'0'),s=String(now.getSeconds()).padStart(2,'0'),ampm=h>=12?'PM':'AM';
    h=h%12||12;
    document.getElementById('home-clock').textContent=h+':'+m+':'+s+' '+ampm;
  }
  tick();setInterval(tick,1000);
}

// ── NAVIGATION ──
function goPage(name){
  curPage=name;
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.sb-item').forEach(b=>b.classList.remove('active'));
  document.getElementById('pg-'+name).classList.add('active');
  const si=document.getElementById('sbi-'+name);
  if(si)si.classList.add('active');
  const tb=document.getElementById('topbar');
  if(name==='home'){tb.classList.remove('show');}
  else{tb.classList.add('show');}
  if(name==='games'){renderGames();}
}

// ── SIDEBAR ──
function toggleSidebar(){
  sbCollapsed=!sbCollapsed;
  const sb=document.getElementById('sidebar');
  const btn=document.getElementById('sb-toggle');
  sb.classList.toggle('collapsed',sbCollapsed);
  btn.innerHTML=sbCollapsed?'&#8250;':'&#8249;';
}

// ── THEMES ──
function applyTheme(cls){
  document.body.className=cls;
  curTheme=cls;
  localStorage.setItem('moon-theme',cls);
}
function setTheme(cls,el){
  applyTheme(cls);
  document.querySelectorAll('.th-chip').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  showToast('Theme applied');
}

// ── FILTER / RENDER ──
function setFilter(f,el){
  curFilter=f;
  document.querySelectorAll('.fb').forEach(b=>b.classList.remove('on'));
  el.classList.add('on');
  renderGames();
}
function onTopSearch(){
  curSearch=document.getElementById('topbar-search').value.toLowerCase();
  renderGames();
}
function renderGames(){
  const grid=document.getElementById('ggrid');
  const nores=document.getElementById('nores');
  const fil=GAMES.filter(g=>(curFilter==='all'||g.t===curFilter)&&(!curSearch||g.n.toLowerCase().includes(curSearch)));
  document.getElementById('tbc').textContent=fil.length;
  if(!fil.length){grid.innerHTML='';nores.classList.add('show');return;}
  nores.classList.remove('show');
  grid.innerHTML=fil.map((g,i)=>{
    const sn=g.n.replace(/'/g,"\\'"),su=g.u.replace(/'/g,"\\'");
    return `<div class="gcard" onclick="openGame('${su}','${sn}','${g.t}')" style="animation-delay:${Math.min(i*.01,.35)}s">
      <div class="gcard-art">${g.e||EMOJI[g.t]||'🎮'}</div>
      <div class="gcard-body">
        <div class="gcard-name">${g.n}</div>
        <div class="gcard-tag">${TL[g.t]||g.t}</div>
      </div>
    </div>`;
  }).join('');
}

// ── HOME SEARCH ──
function homeSearch(){
  const v=document.getElementById('home-search').value.trim().toLowerCase();
  if(!v)return;
  // detect if it's a filter name
  const fmap={html5:'html5',flash:'flash',emulated:'emulated',fnf:'fnf',cdn:'cdn'};
  let matched=Object.keys(fmap).find(k=>v===k||v.includes(k));
  if(matched){
    curFilter=matched;curSearch='';
    document.querySelectorAll('.fb').forEach(b=>b.classList.remove('on'));
    const fb=document.getElementById('fb-'+matched);if(fb)fb.classList.add('on');
  } else {
    curSearch=v;curFilter='all';
    document.querySelectorAll('.fb').forEach(b=>b.classList.remove('on'));
    document.getElementById('fb-all').classList.add('on');
  }
  goPage('games');
  document.getElementById('topbar-search').value=v;
}
function quickFilter(f){
  curFilter=f;curSearch='';
  document.querySelectorAll('.fb').forEach(b=>b.classList.remove('on'));
  const fb=document.getElementById('fb-'+f);if(fb)fb.classList.add('on');
  document.getElementById('topbar-search').value='';
  goPage('games');
}

// ── OPEN GAME ──
function getDriveId(u){const m=u.match(/\/file\/d\/([a-zA-Z0-9_-]+)/);return m?m[1]:null;}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');}

function openGame(url,name,type){
  const style=document.getElementById('s-launch-style')?.value||launchStyle;
  const isCDN=url.includes('jsdelivr')||url.includes('rawcdn.githack')||url.includes('raw.githubusercontent');

  if(isCDN){
    showToast('Loading '+name+'…');
    if(url.endsWith('.swf')){
      fetch(url).then(r=>r.arrayBuffer()).then(buf=>launchRuffle(name,buf)).catch(()=>window.open(url,'_blank'));
    } else {
      fetch(url).then(r=>r.text()).then(html=>writeBlank(name,html)).catch(()=>window.open(url,'_blank'));
    }
    return;
  }
  if(!url.includes('drive.google.com')){
    writeShell(name,`<iframe src="${url}" style="position:absolute;inset:0;width:100%;height:100%;border:none;" allowfullscreen></iframe>`);
    return;
  }
  const id=getDriveId(url);
  if(!id){window.open(url,'_blank');return;}
  showToast('Loading '+name+'…');
  if(type==='flash'){
    fetch(`https://drive.google.com/uc?export=download&id=${id}&confirm=t`)
      .then(r=>r.arrayBuffer()).then(buf=>launchRuffle(name,buf))
      .catch(()=>openDrivePreview(id,name));
  } else {
    fetch(`https://drive.google.com/uc?export=download&id=${id}&confirm=t`)
      .then(r=>r.text())
      .then(html=>{
        if(html.includes('Virus scan warning')||html.includes('<form')&&html.includes('confirm=')){
          const m=html.match(/action="([^"]*uc\?[^"]*)"/);
          if(m){fetch(m[1].replace(/&amp;/g,'&')).then(r2=>r2.text()).then(html2=>writeBlank(name,html2)).catch(()=>openDrivePreview(id,name));}
          else openDrivePreview(id,name);
        } else writeBlank(name,html);
      }).catch(()=>openDrivePreview(id,name));
  }
}

function writeBlank(name,html){
  const w=window.open('about:blank','_blank');
  if(!w){alert('Allow popups!');return;}
  w.document.open();w.document.write(html);w.document.close();
  try{w.document.title=name;}catch(e){}
  showToast(name+' launched!');
}
function writeShell(name,inner){
  const w=window.open('about:blank','_blank');
  if(!w){alert('Allow popups!');return;}
  const tab=document.getElementById('s-tab-title')?.value||'Google Classroom';
  w.document.open();
  w.document.write(`<!DOCTYPE html><html><head><title>${esc(tab)}</title><style>*{margin:0;padding:0;box-sizing:border-box}body{background:#000;display:flex;flex-direction:column;height:100vh;font-family:monospace}#b{background:#111;border-bottom:1px solid #333;padding:6px 14px;display:flex;align-items:center;flex-shrink:0}#b span{color:#7c6aff;font-weight:bold;flex:1;font-size:13px}#b button{background:#e63946;border:none;color:#fff;font-size:11px;padding:4px 12px;cursor:pointer;border-radius:4px}#c{flex:1;position:relative}</style></head><body><div id="b"><span>▶ ${esc(name)}</span><button onclick="window.close()">Close</button></div><div id="c">${inner}</div></body></html>`);
  w.document.close();
}
function launchRuffle(name,buf){
  const blob=new Blob([buf],{type:'application/x-shockwave-flash'});
  const swfURL=URL.createObjectURL(blob);
  const w=window.open('about:blank','_blank');
  if(!w){alert('Allow popups!');return;}
  w.document.open();
  w.document.write(`<!DOCTYPE html><html><head><title>${esc(name)}</title><script src="https://unpkg.com/@ruffle-rs/ruffle"><\/script><style>*{margin:0;padding:0;box-sizing:border-box}body{background:#000;display:flex;flex-direction:column;height:100vh;font-family:monospace}#b{background:#111;border-bottom:1px solid #333;padding:6px 14px;display:flex;align-items:center;flex-shrink:0}#b span{color:#7c6aff;font-weight:bold;flex:1;font-size:13px}#b button{background:#e63946;border:none;color:#fff;font-size:11px;padding:4px 12px;cursor:pointer;border-radius:4px}#s{flex:1;display:flex}</style></head><body><div id="b"><span>▶ ${esc(name)}</span><button onclick="window.close()">Close</button></div><div id="s"></div><script>window.addEventListener('load',function(){var r=window.RufflePlayer.newest();var p=r.createPlayer();p.style.width='100%';p.style.height='100%';p.style.flex='1';document.getElementById('s').appendChild(p);p.load('${swfURL}');});<\/script></body></html>`);
  w.document.close();
  showToast(name+' launched!');
}
function openDrivePreview(id,name){
  writeShell(name,`<iframe src="https://drive.google.com/file/d/${id}/preview" style="position:absolute;inset:0;width:100%;height:100%;border:none;" allowfullscreen></iframe>`);
}

// ── CLOAK ──
function cloakBlank(){const w=window.open('about:blank','_blank');if(!w){alert('Allow popups!');return;}w.document.open();w.document.write(document.documentElement.outerHTML);w.document.close();w.document.title='Google Classroom';window.location.href='https://classroom.google.com';}
function cloakBlob(){const b=new Blob([document.documentElement.outerHTML],{type:'text/html'});const u=URL.createObjectURL(b);const w=window.open(u,'_blank');if(!w){alert('Allow popups!');return;}setTimeout(()=>URL.revokeObjectURL(u),8000);window.location.href='https://classroom.google.com';}

