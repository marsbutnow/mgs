<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Moon</title>
<script src="https://unpkg.com/@ruffle-rs/ruffle"></script>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ── THEMES ── */
:root{
  --bg:#0c0c10;--bg2:#13131a;--s:#1c1c26;--s2:#22222f;
  --a:#7c6aff;--a2:#a89cff;--a3:#4ade80;
  --text:#e8e6f0;--dim:#5a5870;--border:#2a2838;
  --glow:rgba(124,106,255,.3);--page:home;
}
.th-neon{--bg:#040410;--bg2:#080820;--s:#0d0d28;--s2:#121232;--a:#00f5ff;--a2:#80fafe;--a3:#ff00aa;--text:#e0f0ff;--dim:#3a4a80;--border:#1a1a50;--glow:rgba(0,245,255,.25);}
.th-ember{--bg:#0e0600;--bg2:#160900;--s:#1e0e00;--s2:#261400;--a:#ff7a00;--a2:#ffb347;--a3:#ffdd44;--text:#fff0d0;--dim:#7a4010;--border:#3a1800;--glow:rgba(255,122,0,.25);}
.th-hacker{--bg:#000400;--bg2:#010802;--s:#010c02;--s2:#031203;--a:#00ff41;--a2:#00cc33;--a3:#39ff14;--text:#00ff41;--dim:#006615;--border:#003300;--glow:rgba(0,255,65,.2);}
.th-ice{--bg:#00060f;--bg2:#000d1a;--s:#001525;--s2:#001e35;--a:#00cfff;--a2:#80e8ff;--a3:#fff;--text:#cceeff;--dim:#2a5580;--border:#003355;--glow:rgba(0,207,255,.25);}
.th-blood{--bg:#0a0000;--bg2:#120000;--s:#180000;--s2:#200000;--a:#cc0000;--a2:#ff4444;--a3:#ff8888;--text:#ffd0d0;--dim:#660020;--border:#3a0000;--glow:rgba(204,0,0,.25);}
.th-abyss{--bg:#020008;--bg2:#05000f;--s:#09001a;--s2:#0d0022;--a:#9b59ff;--a2:#c899ff;--a3:#ff59cc;--text:#d0c0ff;--dim:#4a2a80;--border:#1a0040;--glow:rgba(155,89,255,.25);}
.th-coffee{--bg:#100a04;--bg2:#180e06;--s:#221408;--s2:#2c1a0c;--a:#c8813a;--a2:#e8b06a;--a3:#f0d090;--text:#f0e0c8;--dim:#7a5530;--border:#4a2e14;--glow:rgba(200,129,58,.2);}
.th-white{--bg:#f4f4f8;--bg2:#fff;--s:#fff;--s2:#f0f0f8;--a:#5a4fff;--a2:#7a6fff;--a3:#e63946;--text:#1a1830;--dim:#9090b0;--border:#dde0f0;--glow:rgba(90,79,255,.18);}

*{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;transition:background .35s,color .35s;}

/* ── LAYOUT ── */
#app{display:flex;height:100vh;overflow:hidden;}

/* ── SIDEBAR ── */
#sidebar{
  width:220px;flex-shrink:0;
  background:var(--bg2);border-right:1px solid var(--border);
  display:flex;flex-direction:column;
  padding:24px 14px 18px;gap:6px;
  transition:width .25s,background .35s,border-color .35s;
  z-index:100;
}
#sidebar.collapsed{width:58px;}
.sb-logo{
  display:flex;align-items:center;gap:10px;
  padding:8px 10px 18px;
  font-family:'Syne',sans-serif;font-size:22px;font-weight:800;
  letter-spacing:-.5px;color:var(--a2);
  white-space:nowrap;overflow:hidden;
}
.sb-logo span{color:var(--text);font-size:11px;font-weight:400;font-family:'JetBrains Mono',monospace;letter-spacing:2px;opacity:.5;align-self:flex-end;padding-bottom:2px;}
#sidebar.collapsed .sb-logo span,
#sidebar.collapsed .sb-nav-label,
#sidebar.collapsed .sb-section{display:none;}
.sb-nav{display:flex;flex-direction:column;gap:3px;flex:1;}
.sb-item{
  display:flex;align-items:center;gap:10px;
  padding:9px 10px;border-radius:10px;
  cursor:pointer;font-size:13px;font-weight:500;
  color:var(--dim);transition:all .15s;white-space:nowrap;overflow:hidden;
  border:1px solid transparent;
  background:none;width:100%;text-align:left;
}
.sb-item:hover{background:var(--s);color:var(--text);}
.sb-item.active{background:var(--s2);color:var(--a2);border-color:var(--border);}
.sb-icon{font-size:15px;flex-shrink:0;width:20px;text-align:center;font-style:normal;font-family:'JetBrains Mono',monospace;}
.sb-nav-label{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:2px;color:var(--dim);padding:10px 10px 4px;text-transform:uppercase;}
.sb-sep{height:1px;background:var(--border);margin:6px 4px;}
.sb-collapse{
  display:flex;align-items:center;justify-content:center;
  padding:8px;border-radius:8px;cursor:pointer;
  color:var(--dim);font-size:14px;transition:all .15s;
  border:1px solid transparent;background:none;width:100%;
}
.sb-collapse:hover{background:var(--s);color:var(--text);}

/* ── MAIN CONTENT ── */
#main{flex:1;display:flex;flex-direction:column;overflow:hidden;position:relative;}

/* ── TOP BAR (non-home) ── */
#topbar{
  height:44px;flex-shrink:0;
  background:rgba(12,12,16,.7);backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
  display:none;align-items:center;gap:12px;padding:0 20px;
  position:relative;z-index:50;
}
#topbar.show{display:flex;}
#topbar-logo{font-family:'Syne',sans-serif;font-size:16px;font-weight:800;color:var(--a2);letter-spacing:-.3px;}
#topbar-search{
  flex:1;max-width:320px;
  background:var(--s);border:1px solid var(--border);
  color:var(--text);font-family:'JetBrains Mono',monospace;font-size:11px;
  padding:6px 12px;border-radius:20px;outline:none;
  transition:border-color .2s,box-shadow .2s;
}
#topbar-search::placeholder{color:var(--dim);}
#topbar-search:focus{border-color:var(--a);box-shadow:0 0 0 2px var(--glow);}
#topbar-count{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--dim);margin-left:auto;}
#topbar-count b{color:var(--a2);}

/* ── PAGES ── */
.page{display:none;flex:1;overflow-y:auto;overflow-x:hidden;}
.page.active{display:flex;flex-direction:column;}
.page-scroll{flex:1;overflow-y:auto;overflow-x:hidden;}
.page-scroll::-webkit-scrollbar{width:4px;}
.page-scroll::-webkit-scrollbar-track{background:transparent;}
.page-scroll::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}

/* ── HOME PAGE ── */
#pg-home{
  align-items:center;justify-content:center;
  background:radial-gradient(ellipse 80% 60% at 50% 40%,rgba(124,106,255,.08),transparent 70%),var(--bg);
}
.home-inner{text-align:center;display:flex;flex-direction:column;align-items:center;gap:20px;padding:40px 20px;}
.moon-wordmark{
  font-family:'Syne',sans-serif;font-size:clamp(64px,12vw,120px);font-weight:800;
  letter-spacing:-4px;line-height:1;
  background:linear-gradient(135deg,#d0cce8 0%,#9890cc 40%,#6058aa 80%,#3a3488 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.home-time{font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--dim);letter-spacing:3px;}
.home-search-wrap{
  display:flex;gap:8px;margin-top:8px;
  width:100%;max-width:480px;
}
.home-search{
  flex:1;background:var(--s);border:1px solid var(--border);
  color:var(--text);font-family:'JetBrains Mono',monospace;font-size:13px;
  padding:12px 18px;border-radius:14px;outline:none;
  transition:border-color .2s,box-shadow .2s;
}
.home-search::placeholder{color:var(--dim);}
.home-search:focus{border-color:var(--a);box-shadow:0 0 0 3px var(--glow);}
.home-go{
  background:var(--a);border:none;color:#fff;
  font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:500;
  letter-spacing:1px;padding:12px 20px;border-radius:14px;cursor:pointer;
  transition:opacity .15s,transform .15s;
}
.home-go:hover{opacity:.85;transform:translateY(-1px);}
.home-chips{display:flex;gap:6px;flex-wrap:wrap;justify-content:center;max-width:480px;}
.home-chip{
  background:var(--s);border:1px solid var(--border);color:var(--dim);
  font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:1px;
  padding:5px 12px;border-radius:20px;cursor:pointer;transition:all .15s;
  text-transform:uppercase;
}
.home-chip:hover{border-color:var(--a);color:var(--a2);background:var(--s2);}
.home-stats{
  display:flex;gap:24px;margin-top:4px;
}
.hstat{text-align:center;}
.hstat-n{font-family:'Syne',sans-serif;font-size:28px;font-weight:800;color:var(--a2);}
.hstat-l{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;margin-top:2px;}

/* ── GAMES PAGE ── */
#pg-games{background:var(--bg);}
.games-inner{padding:24px 24px 80px;}
.page-header{padding:0 0 20px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.page-title{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;color:var(--text);}
.filter-row{display:flex;gap:5px;flex-wrap:wrap;margin-left:auto;}
.fb{background:transparent;border:1px solid var(--border);color:var(--dim);font-family:'JetBrains Mono',monospace;font-size:10px;padding:5px 12px;border-radius:20px;cursor:pointer;letter-spacing:1px;text-transform:uppercase;transition:all .15s;}
.fb:hover,.fb.on{border-color:var(--a);color:var(--a2);background:rgba(124,106,255,.07);}

/* GRID */
.ggrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(164px,1fr));gap:8px;}
.gcard{
  background:var(--s);border:1px solid var(--border);border-radius:12px;
  cursor:pointer;transition:all .18s;overflow:hidden;
  display:flex;flex-direction:column;text-decoration:none;color:inherit;
  animation:gin .24s ease both;
}
.gcard:hover{border-color:var(--a);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.3),0 0 0 1px rgba(124,106,255,.25),0 0 18px var(--glow);}
.gcard-art{
  height:100px;background:var(--bg2);
  display:flex;align-items:center;justify-content:center;
  font-size:36px;position:relative;overflow:hidden;
}
.gcard-art::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(124,106,255,.06),transparent);}
.gcard.sel .gcard-art::after{background:linear-gradient(135deg,rgba(124,106,255,.15),transparent);}
.gcard-body{padding:10px 12px 10px;}
.gcard-name{font-size:12px;font-weight:600;color:var(--text);line-height:1.3;transition:color .15s;}
.gcard:hover .gcard-name{color:var(--a2);}
.gcard-tag{font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:1px;text-transform:uppercase;color:var(--dim);margin-top:4px;}
@keyframes gin{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.nores{display:none;padding:60px 20px;text-align:center;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--dim);letter-spacing:2px;}
.nores.show{display:block;}

/* ── SETTINGS PAGE ── */
#pg-settings{background:var(--bg);}
.spage-inner{padding:24px;display:flex;flex-direction:column;gap:16px;max-width:680px;}
.s-card{background:var(--s);border:1px solid var(--border);border-radius:14px;overflow:hidden;}
.s-card-hdr{padding:14px 18px;border-bottom:1px solid var(--border);background:var(--bg2);}
.s-card-hdr h3{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;color:var(--text);}
.s-card-hdr p{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--dim);margin-top:2px;letter-spacing:.5px;}
.s-card-body{padding:16px 18px;display:flex;flex-direction:column;gap:12px;}
.s-row{display:flex;align-items:center;justify-content:space-between;gap:12px;}
.s-row-lbl{font-size:13px;font-weight:500;color:var(--text);}
.s-row-sub{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--dim);margin-top:1px;}
.s-inp{background:var(--bg2);border:1px solid var(--border);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:12px;padding:8px 12px;border-radius:8px;outline:none;width:100%;transition:border-color .2s;}
.s-inp:focus{border-color:var(--a);}
.s-sel{background:var(--bg2);border:1px solid var(--border);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:11px;padding:7px 10px;border-radius:8px;outline:none;cursor:pointer;}
.s-sel:focus{border-color:var(--a);}
.tog{position:relative;width:40px;height:22px;cursor:pointer;flex-shrink:0;}
.tog input{opacity:0;width:0;height:0;}
.tog-track{position:absolute;inset:0;background:var(--border);border-radius:11px;transition:background .2s;}
.tog input:checked+.tog-track{background:var(--a);}
.tog-thumb{position:absolute;top:3px;left:3px;width:16px;height:16px;background:#fff;border-radius:50%;transition:transform .2s;}
.tog input:checked~.tog-thumb{transform:translateX(18px);}
/* theme grid */
.theme-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;}
.th-chip{border:2px solid var(--border);border-radius:10px;padding:8px 6px;cursor:pointer;text-align:center;transition:all .18s;position:relative;background:var(--bg2);}
.th-chip:hover,.th-chip.on{border-color:var(--a);}
.th-chip.on::after{content:'✓';position:absolute;top:3px;right:5px;font-size:10px;color:var(--a);}
.th-swatch{width:100%;height:20px;border-radius:5px;margin-bottom:5px;}
.th-name{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--dim);}
/* anim scale */
.range-row{display:flex;align-items:center;gap:10px;}
.s-range{flex:1;accent-color:var(--a);cursor:pointer;}
.range-val{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--a2);min-width:28px;text-align:right;}
/* links in settings */
.edu-link{
  display:flex;align-items:center;gap:12px;
  background:var(--bg2);border:1px solid var(--border);border-radius:10px;
  padding:12px 14px;text-decoration:none;color:var(--text);
  transition:all .18s;cursor:pointer;
}
.edu-link:hover{border-color:var(--a);transform:translateY(-1px);}
.edu-link-icon{font-size:20px;flex-shrink:0;}
.edu-link-info{flex:1;}
.edu-link-name{font-size:13px;font-weight:600;}
.edu-link-url{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--dim);margin-top:2px;}
/* disguise options */
.s-btn-row{display:flex;gap:8px;flex-wrap:wrap;}
.s-btn{
  padding:8px 16px;border-radius:8px;border:1px solid var(--border);
  background:transparent;color:var(--dim);font-family:'JetBrains Mono',monospace;
  font-size:10px;letter-spacing:1px;cursor:pointer;transition:all .15s;
}
.s-btn:hover{border-color:var(--a);color:var(--a2);background:rgba(124,106,255,.07);}
.s-btn.primary{background:var(--a);border-color:var(--a);color:#fff;}
.s-btn.primary:hover{opacity:.85;}

/* ── LINKS PAGE ── */
#pg-links{background:var(--bg);}
.links-inner{padding:24px;display:flex;flex-direction:column;gap:24px;max-width:780px;}
.links-section-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;color:var(--text);margin-bottom:10px;}
.links-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px;}
.link-card{
  display:flex;align-items:center;gap:14px;
  background:var(--s);border:1px solid var(--border);border-radius:12px;
  padding:14px 16px;text-decoration:none;color:var(--text);
  transition:all .18s;
}
.link-card:hover{border-color:var(--a);background:var(--s2);transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.3),0 0 16px var(--glow);}
.lc-icon{font-size:22px;flex-shrink:0;}
.lc-name{font-size:14px;font-weight:600;transition:color .15s;}
.link-card:hover .lc-name{color:var(--a2);}
.lc-url{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--dim);margin-top:3px;}
.lc-arrow{font-size:16px;color:var(--dim);margin-left:auto;transition:all .15s;}
.link-card:hover .lc-arrow{color:var(--a2);transform:translateX(3px);}
.discord-banner{
  background:var(--s);border:1px solid var(--border);border-radius:12px;
  padding:16px 20px;display:flex;align-items:center;gap:14px;
}
.dc-icon{font-size:28px;}
.dc-info{flex:1;}
.dc-name{font-size:14px;font-weight:600;color:var(--text);}
.dc-link{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);margin-top:3px;letter-spacing:.5px;user-select:all;}
.dc-note{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--dim);margin-top:4px;opacity:.7;}

/* ── PROXY PAGE ── */
#pg-proxy{background:var(--bg);}
.proxy-inner{padding:24px;display:flex;flex-direction:column;gap:12px;height:100%;}
.proxy-tabs{display:flex;gap:6px;flex-wrap:wrap;}
.ptab{background:transparent;border:1px solid var(--border);color:var(--dim);font-family:'JetBrains Mono',monospace;font-size:10px;padding:6px 14px;border-radius:20px;cursor:pointer;letter-spacing:1px;transition:all .15s;}
.ptab.on{border-color:var(--a);color:var(--a2);background:rgba(124,106,255,.07);}
.proxy-frame-wrap{flex:1;border-radius:12px;overflow:hidden;border:1px solid var(--border);min-height:300px;}
.proxy-frame{width:100%;height:100%;border:none;background:#fff;}

/* ── HTML RUNNER ── */
#html-runner{position:fixed;inset:0;z-index:9000;background:var(--bg);display:none;flex-direction:column;}
#html-runner.open{display:flex;}
.run-topbar{display:flex;align-items:center;gap:8px;padding:8px 16px;background:var(--bg2);border-bottom:1px solid var(--border);flex-shrink:0;flex-wrap:wrap;}
.run-title{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--a2);}
.run-tabs{display:flex;gap:4px;}
.rtab{background:transparent;border:1px solid var(--border);color:var(--dim);font-family:'JetBrains Mono',monospace;font-size:10px;padding:5px 12px;border-radius:6px;cursor:pointer;letter-spacing:1px;transition:all .15s;}
.rtab.on{border-color:var(--a);color:var(--a2);background:rgba(124,106,255,.08);}
.rtab.has-code::after{content:'';display:inline-block;width:5px;height:5px;border-radius:50%;background:var(--a2);margin-left:5px;vertical-align:middle;}
.run-btns{display:flex;gap:5px;margin-left:auto;}
.rb{background:transparent;border:1px solid var(--border);color:var(--dim);font-family:'JetBrains Mono',monospace;font-size:10px;padding:5px 11px;border-radius:6px;cursor:pointer;transition:all .15s;}
.rb:hover{border-color:var(--a);color:var(--a2);}
.rb.run{background:var(--a);border-color:var(--a);color:#fff;}
.rb.cls{border-color:#cc2222;color:#cc2222;}
.rpane{display:none;flex:1;overflow:hidden;}
.rpane.on{display:flex;}
.rsplit{display:flex;flex:1;height:100%;}
.rcode{flex:1;resize:none;background:var(--bg);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:12px;border:none;border-right:1px solid var(--border);padding:14px;outline:none;tab-size:2;line-height:1.6;}
.rpreview{flex:1;border:none;background:#fff;}

/* ── TOAST ── */
#toast{position:fixed;bottom:70px;left:50%;transform:translateX(-50%);background:var(--s2);border:1px solid var(--a);color:var(--a2);font-family:'JetBrains Mono',monospace;font-size:11px;padding:8px 20px;border-radius:20px;z-index:99999;opacity:0;transition:opacity .25s;pointer-events:none;white-space:nowrap;letter-spacing:1px;}
#toast.show{opacity:1;}

/* ── PASSWORD ── */
#pwscreen{position:fixed;inset:0;z-index:99999;background:var(--bg);display:flex;align-items:center;justify-content:center;}
#pwscreen.gone{display:none;}
.pw-box{background:var(--s);border:1px solid var(--border);border-radius:20px;padding:44px 36px 36px;width:340px;display:flex;flex-direction:column;gap:16px;align-items:center;box-shadow:0 24px 60px rgba(0,0,0,.5);}
.pw-logo{font-family:'Syne',sans-serif;font-size:48px;font-weight:800;color:var(--a2);letter-spacing:-2px;}
.pw-title{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;color:var(--text);letter-spacing:-.3px;}
.pw-sub{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--dim);letter-spacing:2px;text-align:center;}
.pw-inp{width:100%;background:var(--bg2);border:1px solid var(--border);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:16px;padding:12px 16px;border-radius:10px;outline:none;text-align:center;letter-spacing:6px;transition:border-color .2s,box-shadow .2s;}
.pw-inp:focus{border-color:var(--a);box-shadow:0 0 0 3px var(--glow);}
.pw-inp.bad{border-color:#e63946;animation:shake .35s ease;}
