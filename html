function getDriveDirectURL(url) {
  // Convert /file/d/ID/view  →  uc?export=download&id=ID&confirm=t
  const m = url.match(/\/file\/d\/([a-zA-Z0-9_-]+)/);
  if(m) return `https://drive.google.com/uc?export=download&id=${m[1]}&confirm=t`;
  return url;
}

// ═══════════════════════════════════════════════════════
//  GAME LAUNCHING — fetch + write to about:blank (like UGS method)
// ═══════════════════════════════════════════════════════
let currentGame = null;

function openGame(url, name, type) {
  currentGame = {url, name, type};

  // For online (non-drive) games open directly
  if(!url.includes('drive.google.com')) {
    launchInWindow(url, name);
    return;
  }

  const directURL = getDriveDirectURL(url);

  // Show loading toast
  showToast('Loading ' + name + '...');

  // Fetch the single-file HTML from Drive and inject into about:blank
  fetch(directURL + '&t=' + Date.now())
    .then(r => {
      if(!r.ok) throw new Error('Drive fetch failed: ' + r.status);
      return r.text();
    })
    .then(html => {
      const newWin = window.open('about:blank', '_blank');
      if(!newWin) { alert('Allow popups to play games!'); return; }
      newWin.document.open();
      newWin.document.write(html);
      newWin.document.close();
      newWin.document.title = name;
    })
    .catch(err => {
      console.warn('Fetch failed, falling back to preview embed:', err);
      // Fallback: open Google Drive preview in new tab
      const m = url.match(/\/file\/d\/([a-zA-Z0-9_-]+)/);
      if(m) {
        window.open(`https://drive.google.com/file/d/${m[1]}/preview`, '_blank');
      } else {
        window.open(url, '_blank');
      }
    });
}

function launchInWindow(url, name) {
  const newWin = window.open('about:blank', '_blank');
  if(!newWin) { window.open(url, '_blank'); return; }
  newWin.document.open();
  newWin.document.write(`<!DOCTYPE html><html><head><title>${name}</title>
  <style>*{margin:0;padding:0;box-sizing:border-box}body{background:#000;display:flex;flex-direction:column;height:100vh;overflow:hidden}
  #bar{background:#111;border-bottom:1px solid #222;padding:6px 12px;display:flex;align-items:center;gap:10px;font-family:monospace;font-size:12px;color:#555;flex-shrink:0}
  #bar span{color:#e63946;font-weight:bold}button{margin-left:auto;background:#e63946;border:none;color:#fff;font-size:11px;padding:4px 10px;cursor:pointer;font-family:monospace}
  iframe{flex:1;width:100%;border:none}</style></head><body>
  <div id="bar"><span>▶ ${name}</span><button onclick="window.close()">✕ CLOSE</button></div>
  <iframe src="${url}" allowfullscreen allow="fullscreen *"></iframe>
  </body></html>`);
  newWin.document.close();
}

