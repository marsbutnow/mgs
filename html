  document.querySelectorAll('.theme-option').forEach(o => o.classList.remove('active'));
  if(el) el.classList.add('active');
  localStorage.setItem('mgs-theme', t);
}
function toggleThemePanel() {
  document.getElementById('theme-panel').classList.toggle('open');
}
document.addEventListener('click', e => {
  const p = document.getElementById('theme-panel');
  if(p.classList.contains('open') && !p.contains(e.target) && !e.target.closest('#toolbar')) p.classList.remove('open');
});

