<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Mars Game Stash</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Rajdhani:wght@400;600&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
/* ── THEMES ── */
:root{
  --a:#00d4ff;--a2:#e63946;--bg:#07090f;--bg2:#0d1220;
  --card:#111827;--text:#c8d6e5;--dim:#3a5a7a;--border:#1a2a40;
  --glow:rgba(0,212,255,.55);
}
.theme-pink{--a:#ff69b4;--a2:#ff1493;--glow:rgba(255,105,180,.6);--bg:#100010;--bg2:#1a0015;--card:#1f0018;--border:#4a0035;--dim:#8a3060;}
.theme-maroon{--a:#cc2222;--a2:#ff6666;--glow:rgba(200,34,34,.6);--bg:#0f0000;--bg2:#1a0000;--card:#220000;--border:#440000;--dim:#883333;}
.theme-hacker{--a:#00ff00;--a2:#33ff33;--glow:rgba(0,255,0,.55);--bg:#000;--bg2:#010f01;--card:#001400;--border:#004000;--dim:#006600;}
.theme-choco{--a:#c8853a;--a2:#f0c080;--glow:rgba(200,133,58,.55);--bg:#1a0f05;--bg2:#261507;--card:#321c09;--border:#5a3010;--dim:#9a7040;}
.theme-rainbow{--a:#ff0080;--a2:#00ffcc;--glow:rgba(255,0,128,.55);--bg:#0a0a0a;--bg2:#111;--card:#151515;--border:#222;--dim:#555;}
.theme-light{--a:#0077cc;--a2:#e63946;--glow:rgba(0,119,204,.4);--bg:#e8edf5;--bg2:#dce4ef;--card:#fff;--border:#c0cfe0;--dim:#7090b0;--text:#1a202c;}

*{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;overflow:hidden;}
body{
  background:var(--bg);color:var(--text);
  font-family:'Rajdhani',sans-serif;
  display:flex;flex-direction:column;
  transition:background .3s,color .3s;
}

/* ── SCANLINES ── */
body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:9999;
  background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.022) 2px,rgba(0,0,0,.022) 4px);}

/* ── HEADER ── */
#hdr{
  flex-shrink:0;padding:14px 28px 10px;
  border-bottom:1px solid var(--border);
  background:rgba(0,0,0,.3);backdrop-filter:blur(10px);
  display:flex;align-items:center;gap:14px;
}
.planet{width:30px;height:30px;border-radius:50%;flex-shrink:0;
  background:radial-gradient(circle at 35% 35%,#ff6666,#cc0000 50%,#660000);
  box-shadow:0 0 14px rgba(230,57,70,.6);}
.logo{font-family:'Orbitron',sans-serif;font-size:clamp(16px,2.5vw,26px);
  font-weight:900;letter-spacing:3px;}
.logo-m{color:var(--a2);}.logo-g{color:var(--a);}
#hdr-right{margin-left:auto;display:flex;align-items:center;gap:10px;}
#user-pill{font-family:'Share Tech Mono',monospace;font-size:11px;
  color:var(--a);background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.2);
  padding:4px 10px;border-radius:20px;letter-spacing:1px;}

/* ── GAME STAGE ── */
#stage{
  flex:1;position:relative;display:flex;align-items:center;justify-content:center;
  overflow:hidden;perspective:900px;
}

/* BG glow blob */
#stage::before{content:'';position:absolute;
  width:500px;height:200px;border-radius:50%;
  background:radial-gradient(ellipse,var(--glow) 0%,transparent 70%);
  opacity:.18;pointer-events:none;transition:background .4s;}

/* ── CARD TRACK ── */
#track{
  display:flex;align-items:center;gap:28px;
  transition:transform .38s cubic-bezier(.22,1,.36,1);
  position:relative;
}

/* ── SINGLE CARD ── */
.gc{
  flex-shrink:0;
  width:220px;height:300px;
  border-radius:18px;
  background:var(--card);
  border:2px solid var(--border);
  cursor:pointer;
  position:relative;
  transition:
    transform .38s cubic-bezier(.22,1,.36,1),
    box-shadow .38s ease,
    border-color .38s ease,
    opacity .38s ease;
  transform:scale(.78) rotateY(8deg);
  opacity:.55;
  display:flex;flex-direction:column;
  overflow:hidden;
}
.gc.sel{
  transform:scale(1) rotateY(0deg);
  opacity:1;
  border-color:var(--a);
  box-shadow:
    0 0 0 2px var(--a),
    0 0 30px var(--glow),
    0 0 60px rgba(0,0,0,.6);
  animation:pulse-border 2s ease-in-out infinite;
}
.gc.left-adj{transform:scale(.82) rotateY(10deg);opacity:.6;}
.gc.right-adj{transform:scale(.82) rotateY(-10deg);opacity:.6;}
@keyframes pulse-border{
  0%,100%{box-shadow:0 0 0 2px var(--a),0 0 22px var(--glow),0 0 50px rgba(0,0,0,.5);}
  50%{box-shadow:0 0 0 2px var(--a),0 0 42px var(--glow),0 0 70px rgba(0,0,0,.5);}
}

/* card cover art area */
.gc-art{
  height:170px;background:var(--bg2);position:relative;
  overflow:hidden;flex-shrink:0;
}
.gc-art-inner{
  width:100%;height:100%;
  display:flex;align-items:center;justify-content:center;
  font-size:48px;letter-spacing:0;
  background:linear-gradient(135deg,var(--bg2) 0%,rgba(0,0,0,.4) 100%);
  position:relative;
}
/* shimmer on selected */
.gc.sel .gc-art-inner::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(120deg,transparent 30%,rgba(255,255,255,.06) 50%,transparent 70%);
  animation:shimmer 2.5s ease-in-out infinite;
}
@keyframes shimmer{0%{transform:translateX(-100%);}100%{transform:translateX(100%);}}

.gc-tag{
  position:absolute;top:10px;right:10px;
  font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:1px;
  color:#fff;padding:3px 7px;border-radius:4px;text-transform:uppercase;
  background:rgba(0,0,0,.6);border:1px solid rgba(255,255,255,.15);
}

/* card info */
.gc-info{padding:14px 14px 10px;flex:1;display:flex;flex-direction:column;gap:5px;}
.gc-name{font-family:'Orbitron',sans-serif;font-size:12px;font-weight:700;
  letter-spacing:.5px;line-height:1.3;color:var(--text);}
.gc.sel .gc-name{color:var(--a);}
.gc-size{font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--dim);}
.gc-enter{
  margin-top:auto;padding:7px 12px;border-radius:8px;
  background:var(--a);color:#000;font-family:'Orbitron',monospace;
  font-size:9px;letter-spacing:2px;font-weight:700;
  text-align:center;opacity:0;transition:opacity .3s;
}
.gc.sel .gc-enter{opacity:1;}

/* ── SEARCH ── */
#search-wrap{
  flex-shrink:0;padding:10px 28px 6px;
  display:flex;align-items:center;gap:10px;
  background:rgba(0,0,0,.25);
}
#search{
  flex:1;max-width:420px;
  background:var(--bg2);border:1px solid var(--border);
  color:var(--text);font-family:'Share Tech Mono',monospace;
  font-size:13px;padding:9px 14px;border-radius:10px;
  outline:none;transition:border-color .2s,box-shadow .2s;
}
#search::placeholder{color:var(--dim);}
#search:focus{border-color:var(--a);box-shadow:0 0 0 2px rgba(0,212,255,.15);}
#search-count{font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--dim);}
#search-count span{color:var(--a);}
.filter-wrap{display:flex;gap:6px;flex-wrap:wrap;}
.fb{background:transparent;border:1px solid var(--border);color:var(--dim);
  font-family:'Share Tech Mono',monospace;font-size:10px;
  padding:5px 12px;border-radius:20px;cursor:pointer;letter-spacing:1px;
  text-transform:uppercase;transition:all .18s;}
.fb:hover,.fb.on{border-color:var(--a);color:var(--a);background:rgba(0,212,255,.07);}

/* ── BOTTOM BAR ── */
#bot{
  flex-shrink:0;padding:10px 20px;
  background:rgba(0,0,0,.5);backdrop-filter:blur(12px);
  border-top:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;gap:8px;flex-wrap:wrap;
}
.bb{
  background:rgba(255,255,255,.06);border:1px solid var(--border);
  color:var(--dim);font-family:'Share Tech Mono',monospace;
  font-size:10px;padding:7px 16px;border-radius:30px;cursor:pointer;
  letter-spacing:1px;text-transform:uppercase;transition:all .18s;
}
.bb:hover{border-color:var(--a);color:var(--a);background:rgba(0,212,255,.08);}
.bb.accent{border-color:var(--a2);color:var(--a2);}
.bb.accent:hover{background:rgba(230,57,70,.12);}
.bb.blob{border-color:#a855f7;color:#a855f7;}
.bb.blob:hover{background:rgba(168,85,247,.12);}
#nav-hint{font-family:'Share Tech Mono',monospace;font-size:10px;
  color:var(--dim);letter-spacing:1px;margin-right:auto;}

/* ── SETTINGS MODAL ── */
#sov{position:fixed;inset:0;z-index:8000;background:rgba(0,0,0,.75);
  backdrop-filter:blur(5px);display:none;align-items:center;justify-content:center;}
#sov.open{display:flex;}
.sbox{background:var(--bg2);border:1px solid var(--border);
  border-radius:16px;width:420px;max-width:95vw;max-height:85vh;overflow-y:auto;
  box-shadow:0 0 40px rgba(0,0,0,.6);}
.sh{padding:18px 22px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;}
.st{font-family:'Orbitron',sans-serif;font-size:13px;letter-spacing:3px;color:var(--a);}
.sc{background:none;border:none;color:var(--dim);cursor:pointer;font-size:18px;}
.ss{padding:16px 22px;}
.sl{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:3px;color:var(--a2);margin-bottom:12px;text-transform:uppercase;}
.tg{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;}
.tc{border:2px solid var(--border);border-radius:10px;padding:7px 5px;cursor:pointer;text-align:center;transition:all .18s;position:relative;}
.tc:hover,.tc.on{border-color:var(--a);}
.tc.on::after{content:'✓';position:absolute;top:3px;right:5px;font-size:10px;color:var(--a);}
.tsw{width:100%;height:22px;border-radius:5px;margin-bottom:5px;}
.tnm{font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--dim);}

/* ── LOGIN SCREEN ── */
#ls{position:fixed;inset:0;z-index:9000;background:#050810;
  display:flex;align-items:center;justify-content:center;flex-direction:column;}
#ls.gone{display:none;}
.lb{background:rgba(15,22,39,.98);border:1px solid #1a2a40;
  border-radius:16px;padding:44px 36px 36px;width:340px;position:relative;}
.lpl{width:52px;height:52px;border-radius:50%;margin:0 auto 12px;
  background:radial-gradient(circle at 35% 35%,#ff6666,#cc0000 50%,#660000);
  box-shadow:0 0 24px rgba(230,57,70,.5);}
.lh{font-family:'Orbitron',sans-serif;font-size:18px;font-weight:900;
  letter-spacing:4px;color:#00d4ff;text-align:center;text-shadow:0 0 16px rgba(0,212,255,.5);}
.lsub{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:3px;
  color:#3a5a7a;text-align:center;margin:4px 0 26px;}
.lf label{display:block;font-family:'Share Tech Mono',monospace;font-size:10px;
  letter-spacing:2px;color:#3a5a7a;text-transform:uppercase;margin-bottom:5px;}
.lf{margin-bottom:13px;}
.lf input{width:100%;background:#080b14;border:1px solid #1a2a40;color:#c8d6e5;
  font-family:'Share Tech Mono',monospace;font-size:13px;padding:9px 12px;
  border-radius:8px;outline:none;transition:border-color .2s;}
.lf input:focus{border-color:#00d4ff;}
.lbtn{width:100%;background:linear-gradient(135deg,#e63946,#c41230);border:none;
  color:#fff;font-family:'Orbitron',sans-serif;font-size:12px;font-weight:700;
  letter-spacing:3px;padding:12px;border-radius:10px;cursor:pointer;margin-top:6px;
  transition:all .2s;}
.lbtn:hover{box-shadow:0 0 18px rgba(230,57,70,.4);}
.lerr{color:#e63946;font-family:'Share Tech Mono',monospace;font-size:11px;
  text-align:center;margin-top:10px;min-height:16px;}

/* ── GAME LAUNCH ── */
#launch{position:fixed;inset:0;z-index:7000;background:var(--bg);display:none;
  flex-direction:column;}
#launch.open{display:flex;}
#launch-bar{
  background:rgba(0,0,0,.8);border-bottom:1px solid var(--border);
  padding:8px 14px;display:flex;align-items:center;gap:10px;flex-shrink:0;
}
#launch-title{font-family:'Share Tech Mono',monospace;font-size:12px;color:var(--a);flex:1;}
.lc-btn{background:none;border:1px solid var(--border);color:var(--dim);
  font-family:'Share Tech Mono',monospace;font-size:10px;
  padding:4px 12px;border-radius:20px;cursor:pointer;transition:all .18s;}
.lc-btn:hover{border-color:var(--a2);color:var(--a2);}
#launch-frame{flex:1;width:100%;border:none;}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="ls">
  <div class="lb">
    <div class="lpl"></div>
    <div class="lh">MARS GAME STASH</div>
    <div class="lsub">// private access only</div>
    <div class="lf"><label>Username</label><input id="lu" type="text" placeholder="username" autocomplete="off"></div>
    <div class="lf"><label>Password</label><input id="lp" type="password" placeholder="password" autocomplete="off" onkeydown="if(event.key==='Enter')doLogin()"></div>
    <button class="lbtn" onclick="doLogin()">ACCESS STASH</button>
    <div class="lerr" id="lerr"></div>
  </div>
</div>

<!-- GAME LAUNCH OVERLAY -->
<div id="launch">
  <div id="launch-bar">
    <span id="launch-title">▶ Loading...</span>
    <button class="lc-btn" onclick="closeLaunch()">✕ CLOSE</button>
  </div>
  <iframe id="launch-frame" src="about:blank" allowfullscreen allow="fullscreen"></iframe>
</div>

<!-- HEADER -->
<div id="hdr">
  <div class="planet"></div>
  <div class="logo"><span class="logo-m">Mars</span> <span class="logo-g">Game Stash</span></div>
  <div id="hdr-right">
    <div id="user-pill">---</div>
  </div>
</div>

<!-- GAME STAGE -->
<div id="stage">
  <div id="track"></div>
</div>

<!-- SEARCH -->
<div id="search-wrap">
  <input id="search" type="text" placeholder="🔍 Search games..." oninput="onSearch()" autocomplete="off">
  <div class="filter-wrap" id="filters">
    <button class="fb on" onclick="setF('all',this)">All</button>
    <button class="fb" onclick="setF('html5',this)">HTML5</button>
    <button class="fb" onclick="setF('flash',this)">Flash</button>
    <button class="fb" onclick="setF('emulated',this)">Emulated</button>
    <button class="fb" onclick="setF('fnf',this)">FNF</button>
    <button class="fb" onclick="setF('pokemon',this)">Pokémon</button>
  </div>
  <div id="search-count"><span id="cnt">0</span> games</div>
</div>

<!-- BOTTOM BAR -->
<div id="bot">
  <span id="nav-hint">◀ ▶ Navigate &nbsp;|&nbsp; ENTER to play &nbsp;|&nbsp; ESC close</span>
  <button class="bb" onclick="openSettings()">⚙ Settings</button>
  <button class="bb blob" onclick="blobCloak()">🫧 Blob Cloak</button>
  <button class="bb accent" onclick="abCloak()">⬛ AB Cloak</button>
  <button class="bb" onclick="doLogout()">⏻ Logout</button>
</div>

<!-- SETTINGS -->
<div id="sov"><div class="sbox">
  <div class="sh"><span class="st">⚙ SETTINGS</span><button class="sc" onclick="closeSett()">✕</button></div>
  <div class="ss">
    <div class="sl">Theme</div>
    <div class="tg">
      <div class="tc on" id="t-dark" onclick="setTheme('',this)"><div class="tsw" style="background:linear-gradient(135deg,#07090f,#1a2a40)"></div><div class="tnm">DARK</div></div>
      <div class="tc" id="t-light" onclick="setTheme('light',this)"><div class="tsw" style="background:linear-gradient(135deg,#e8edf5,#c0cfe0)"></div><div class="tnm">LIGHT</div></div>
      <div class="tc" id="t-pink" onclick="setTheme('pink',this)"><div class="tsw" style="background:linear-gradient(135deg,#100010,#ff69b4)"></div><div class="tnm">PINK</div></div>
      <div class="tc" id="t-rainbow" onclick="setTheme('rainbow',this)"><div class="tsw" style="background:linear-gradient(135deg,#ff0080,#ffcc00,#00ffcc)"></div><div class="tnm">RAINBOW</div></div>
      <div class="tc" id="t-maroon" onclick="setTheme('maroon',this)"><div class="tsw" style="background:linear-gradient(135deg,#0f0000,#cc2222)"></div><div class="tnm">MAROON</div></div>
      <div class="tc" id="t-choco" onclick="setTheme('choco',this)"><div class="tsw" style="background:linear-gradient(135deg,#1a0f05,#c8853a)"></div><div class="tnm">CHOCO</div></div>
      <div class="tc" id="t-hacker" onclick="setTheme('hacker',this)"><div class="tsw" style="background:linear-gradient(135deg,#000,#00ff00)"></div><div class="tnm">HACKER</div></div>
    </div>
  </div>
</div></div>

<script>
// ── ACCOUNTS (no passwords stored — just username check) ──
const USERS={mars:'owner',Elijah:'admin',Eli:'admin',Albert:'admin'};
let CU=null, CT='Google Classroom';

function doLogin(){
  const u=document.getElementById('lu').value.trim();
  const p=document.getElementById('lp').value;
  const e=document.getElementById('lerr');
  // Simple: accept any password, just check username exists
  if(!u){e.textContent='// enter a username';return;}
  const role=USERS[u]||USERS[Object.keys(USERS).find(k=>k.toLowerCase()===u.toLowerCase())];
  if(!role){e.textContent='// username not recognised';return;}
  CU={u,role};
  document.getElementById('ls').classList.add('gone');
  document.getElementById('user-pill').textContent=u.toUpperCase()+' ['+role+']';
  document.title=CT;
  render();
}
function doLogout(){CU=null;document.getElementById('ls').classList.remove('gone');document.getElementById('lu').value='';document.getElementById('lp').value='';document.getElementById('lerr').textContent='';}

// ── CLOAK ──
function abCloak(){const w=window.open('about:blank','_blank');if(!w)return;w.document.open();w.document.write(document.documentElement.outerHTML);w.document.close();w.document.title=CT;window.location.href='https://classroom.google.com';}
function blobCloak(){const b=new Blob([document.documentElement.outerHTML],{type:'text/html'});const u=URL.createObjectURL(b);const w=window.open(u,'_blank');if(w)setTimeout(()=>{try{w.document.title=CT;}catch(e){}},300);}

// ── SETTINGS ──
function openSettings(){document.getElementById('sov').classList.add('open');}
function closeSett(){document.getElementById('sov').classList.remove('open');}
document.getElementById('sov').addEventListener('click',function(e){if(e.target===this)closeSett();});
function setTheme(cls,el){
  document.body.className=cls?'theme-'+cls:'';
  document.querySelectorAll('.tc').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  localStorage.setItem('mgs3-theme',cls);
}
const st=localStorage.getItem('mgs3-theme');
if(st){document.body.className=st?'theme-'+st:'';const el=document.getElementById('t-'+(st||'dark'));if(el){document.querySelectorAll('.tc').forEach(c=>c.classList.remove('on'));el.classList.add('on');}}

// ── GAME DATA ──
const EMOJI={html5:'🖥',flash:'⚡',emulated:'🕹',fnf:'🎵',pokemon:'⚾'};
const GAMES=[
  {n:"Baldi's Basics",u:"https://drive.google.com/file/d/1UeCBcErh14gonxfw0y2amxbrqZfrttKj/view",t:"html5",mb:"~15MB",e:"🏫"},
  {n:"Basket Bros",u:"https://drive.google.com/file/d/1R6OCaS56zMHchP9zsHbxeFXx-3SsPuAU/view",t:"html5",mb:"~20MB",e:"🏀"},
  {n:"Basket Random",u:"https://drive.google.com/file/d/1mq1psi8_H4jyQslycPGSR-dbkWJ1QAW9/view",t:"html5",mb:"~12MB",e:"🏀"},
  {n:"Tomb of the Mask",u:"https://drive.google.com/file/d/1uCr1KuIfZ46DJeOX92ZYY2nlyQ6ulPcs/view",t:"html5",mb:"~18MB",e:"💀"},
  {n:"BitLife",u:"https://drive.google.com/file/d/1qdHWXaWjyk4wvpxf9q6S-lQP9X0DhsTA/view",t:"html5",mb:"~40MB",e:"👤"},
  {n:"Escape Road",u:"https://drive.google.com/file/d/14vjJbM91SrRGqic6DG9CqQ5r5NPKEzMo/view",t:"html5",mb:"~22MB",e:"🚗"},
  {n:"Escape Road 2",u:"https://drive.google.com/file/d/1T5niOq0TmVrDCucQruTIlqF7BpxCdTEY/view",t:"html5",mb:"~28MB",e:"🚗"},
  {n:"Drive Mad",u:"https://drive.google.com/file/d/1_U2IKm5-MY5hUROiO46BaOWy81ym_yhr/view",t:"html5",mb:"~18MB",e:"🚙"},
  {n:"Crazy Cattle 3D",u:"https://drive.google.com/file/d/1l9yA5vMAqkcrH8Jua2LEnD-s-wTIFZ0R/view",t:"html5",mb:"~55MB",e:"🐄"},
  {n:"Cookie Clicker",u:"https://drive.google.com/file/d/1kDlM4BCzn7TMezp94VWPL5RhbFXZIwf-/view",t:"html5",mb:"~8MB",e:"🍪"},
  {n:"Burrito Bison",u:"https://drive.google.com/file/d/1Mvs0de1vB6AtPBHYUpYVaXzUmt2D9QtY/view",t:"html5",mb:"~30MB",e:"🌯"},
