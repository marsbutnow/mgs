  {n:"Mario Kart DS",u:"https://drive.google.com/file/d/1s7m935WOWN1EM6EB8buUid7bbZxKsPa_/view",t:"emulated",mb:"~64MB",e:"🏎"},
  {n:"Sonic the Hedgehog",u:"https://drive.google.com/file/d/1fZZt54aoygf1qkGsYB3HUeHSeQ1nSNcC/view",t:"emulated",mb:"~4MB",e:"💙"},
  {n:"Sonic 3 & Knuckles",u:"https://drive.google.com/file/d/1wgAxyed2gJgekM4eXlkah1uyj47NnZPj/view",t:"emulated",mb:"~8MB",e:"💙"},
  {n:"Doom (MS-DOS)",u:"https://drive.google.com/file/d/1nb8YlAFYC1s_UiuZXCFzYXazyzqK8IPx/view",t:"emulated",mb:"~12MB",e:"👹"},
  {n:"Star Fox 64",u:"https://drive.google.com/file/d/1jWumZ8K20tDPLzTXyb9AHB424KOrub1X/view",t:"emulated",mb:"~64MB",e:"🦊"},
  {n:"Kirby Super Star",u:"https://drive.google.com/file/d/15T1rBO-xuh-6eRFll6epZIVtDb_9ztnU/view",t:"emulated",mb:"~16MB",e:"🌟"},
  {n:"Final Fantasy VII",u:"https://drive.google.com/file/d/13wJl_6BtOljdKG0pbyUWAh-DOAWWtCTm/view",t:"emulated",mb:"~650MB",e:"⚔"},
  {n:"Mortal Kombat SNES",u:"https://drive.google.com/file/d/1rOzt1xOzXR4fn9YJ18NlagGskt3wzg-7/view",t:"emulated",mb:"~16MB",e:"🩸"},
  {n:"Streets of Rage 2",u:"https://drive.google.com/file/d/1Nd8EWA-nk4NHyZYuzU46WGTlSBo5IK7A/view",t:"emulated",mb:"~4MB",e:"🥊"},
];

// ── STATE ──
let filtered=[], idx=0, curFilter='all', curSearch='';

function setF(f,el){
  curFilter=f;
  document.querySelectorAll('.fb').forEach(b=>b.classList.remove('on'));
  el.classList.add('on');
  idx=0;render();
}
function onSearch(){curSearch=document.getElementById('search').value.toLowerCase();idx=0;render();}

function getFiltered(){
  return GAMES.filter(g=>{
    const mf=curFilter==='all'||g.t===curFilter;
    const ms=!curSearch||g.n.toLowerCase().includes(curSearch);
    return mf&&ms;
  });
}

// ── RENDER CARDS ──
function render(){
  filtered=getFiltered();
  document.getElementById('cnt').textContent=filtered.length;
  const track=document.getElementById('track');
  track.innerHTML='';
  if(!filtered.length){track.innerHTML='<div style="font-family:Share Tech Mono,monospace;color:var(--dim);letter-spacing:2px;">NO GAMES FOUND</div>';return;}
  filtered.forEach((g,i)=>{
    const c=document.createElement('div');
    c.className='gc'+(i===idx?' sel':i===idx-1?' left-adj':i===idx+1?' right-adj':'');
    c.dataset.i=i;
    c.innerHTML=`
      <div class="gc-art">
        <div class="gc-art-inner">${g.e||'🎮'}</div>
        <div class="gc-tag">${g.t.toUpperCase()}</div>
      </div>
      <div class="gc-info">
        <div class="gc-name">${g.n}</div>
        <div class="gc-size">${g.mb}</div>
        <div class="gc-enter">▶ PRESS ENTER</div>
      </div>`;
    c.addEventListener('click',()=>{if(parseInt(c.dataset.i)===idx){openGame();}else{idx=parseInt(c.dataset.i);updateSel();}});
    track.appendChild(c);
  });
  scrollToSel();
}

function updateSel(){
  document.querySelectorAll('.gc').forEach((c,i)=>{
    c.className='gc'+(i===idx?' sel':i===idx-1?' left-adj':i===idx+1?' right-adj':'');
    c.dataset.i=i;
  });
  scrollToSel();
}

function scrollToSel(){
  const stage=document.getElementById('stage');
  const track=document.getElementById('track');
  const cards=track.querySelectorAll('.gc');
  if(!cards[idx])return;
  const cardW=220+28; // card width + gap
  const stageW=stage.offsetWidth;
  const offset=(stageW/2)-(cardW*idx)-(220/2);
  track.style.transform=`translateX(${offset}px)`;
}

// ── KEYBOARD ──
document.addEventListener('keydown',e=>{
  if(document.getElementById('ls').classList.contains('gone')===false)return;
  if(document.getElementById('launch').classList.contains('open')){
    if(e.key==='Escape')closeLaunch();
    return;
  }
  if(document.getElementById('sov').classList.contains('open')){
    if(e.key==='Escape')closeSett();
    return;
  }
  if(e.key==='ArrowRight'&&idx<filtered.length-1){idx++;updateSel();e.preventDefault();}
  else if(e.key==='ArrowLeft'&&idx>0){idx--;updateSel();e.preventDefault();}
  else if(e.key==='Enter'){openGame();e.preventDefault();}
  else if(e.key==='Escape'){closeLaunch();}
});

// ── OPEN GAME ──
function openGame(){
  if(!filtered[idx])return;
  const g=filtered[idx];
  document.getElementById('launch-title').textContent='▶ '+g.n;
  document.getElementById('launch-frame').src=g.u;
  document.getElementById('launch').classList.add('open');
}
function closeLaunch(){
  document.getElementById('launch').classList.remove('open');
  document.getElementById('launch-frame').src='about:blank';
}

// ── RESIZE ──
window.addEventListener('resize',scrollToSel);

// ── LOADER / INIT ──
window.addEventListener('load',()=>{
  // slight delay to let fonts load
  setTimeout(()=>{ document.querySelectorAll('#stage,#search-wrap,#bot,#hdr').forEach(el=>el.style.visibility='visible'); },100);
});
</script>
