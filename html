let currentFilter = 'all', currentSearch = '';
const tagLabels = {html5:'HTML5',flash:'Flash ⚡',emulated:'Emulated',fnf:'FNF'};

function setFilter(f, el) {
  currentFilter = f;
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  renderGames();
}
function filterGames() { currentSearch=document.getElementById('search').value.toLowerCase(); renderGames(); }

function renderGames() {
  const grid = document.getElementById('game-grid');
  const noR = document.getElementById('no-results');
  const filtered = games.filter(g => {
    return (currentFilter==='all'||g.t===currentFilter) && (!currentSearch||g.n.toLowerCase().includes(currentSearch));
  });
  document.getElementById('count').textContent = filtered.length;
  if(!filtered.length) { grid.innerHTML=''; noR.classList.add('show'); return; }
  noR.classList.remove('show');
  grid.innerHTML = filtered.map((g,i) => `
    <a class="game-card" href="#" onclick="event.preventDefault();openGame('${g.u.replace(/'/g,"\\'")}','${g.n.replace(/'/g,"\\'")}','${g.t}');" style="animation-delay:${Math.min(i*0.015,0.4)}s">
      <div class="card-tooltip">
        <span class="tooltip-title">${g.n}</span>
        <span class="tooltip-size">Size: ${g.mb} | ${tagLabels[g.t]||g.t}</span>
      </div>
      <div class="card-body">
        <div class="card-name">${g.n}</div>
        <div class="card-tag">${tagLabels[g.t]||g.t}</div>
      </div>
    </a>
  `).join('');
}

