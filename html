<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mars Game Stash</title>
<!-- Ruffle Flash Emulator -->
<script src="https://unpkg.com/@ruffle-rs/ruffle"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Share+Tech+Mono&family=Rajdhani:wght@300;400;600;700&display=swap');

/* ─────────────────────────────────────────────────────── THEMES */
:root, [data-theme="mars"] {
  --bg: #080b14; --bg2: #0d1220; --card: #0f1627; --card-hover: #162035;
  --accent: #e63946; --accent2: #00d4ff; --accent3: #ff6b35;
  --text: #c8d6e5; --text-dim: #5a7a9a; --border: #1a2a40;
  --glow: rgba(0,212,255,0.15); --glow-red: rgba(230,57,70,0.2);
  --header-grad: rgba(0,212,255,0.03); --scan: rgba(0,0,0,0.03);
}
[data-theme="neon"] {
  --bg: #050510; --bg2: #08081a; --card: #0a0a20; --card-hover: #10102a;
  --accent: #ff00ff; --accent2: #00ffaa; --accent3: #ffff00;
  --text: #e0e0ff; --text-dim: #5050aa; --border: #1a1a40;
  --glow: rgba(0,255,170,0.15); --glow-red: rgba(255,0,255,0.2);
  --header-grad: rgba(0,255,170,0.03); --scan: rgba(0,0,0,0.04);
}
[data-theme="hacker"] {
  --bg: #000500; --bg2: #010801; --card: #020c02; --card-hover: #041204;
  --accent: #00ff41; --accent2: #00cc33; --accent3: #39ff14;
  --text: #00ff41; --text-dim: #006614; --border: #003300;
  --glow: rgba(0,255,65,0.15); --glow-red: rgba(0,255,65,0.2);
  --header-grad: rgba(0,255,65,0.03); --scan: rgba(0,0,0,0.06);
}
[data-theme="abyss"] {
  --bg: #02020a; --bg2: #05050f; --card: #07071a; --card-hover: #0c0c22;
  --accent: #7b2fff; --accent2: #ff2fff; --accent3: #2fffff;
  --text: #c5b8ff; --text-dim: #4a3a80; --border: #1a1040;
  --glow: rgba(123,47,255,0.15); --glow-red: rgba(255,47,255,0.2);
  --header-grad: rgba(123,47,255,0.04); --scan: rgba(0,0,0,0.04);
}
[data-theme="ember"] {
  --bg: #0f0600; --bg2: #160900; --card: #1a0c00; --card-hover: #241200;
  --accent: #ff6a00; --accent2: #ffb347; --accent3: #ff3300;
  --text: #ffe0b2; --text-dim: #7a4010; --border: #3a1800;
  --glow: rgba(255,106,0,0.15); --glow-red: rgba(255,51,0,0.2);
  --header-grad: rgba(255,179,71,0.04); --scan: rgba(0,0,0,0.04);
}
[data-theme="ice"] {
  --bg: #00080f; --bg2: #000f1a; --card: #001525; --card-hover: #001e33;
  --accent: #00cfff; --accent2: #80e8ff; --accent3: #ffffff;
  --text: #cceeff; --text-dim: #336688; --border: #003355;
  --glow: rgba(0,207,255,0.15); --glow-red: rgba(128,232,255,0.2);
  --header-grad: rgba(0,207,255,0.04); --scan: rgba(0,0,0,0.03);
}

* { margin:0; padding:0; box-sizing:border-box; }
body {
  background: var(--bg); color: var(--text);
  font-family: 'Rajdhani', sans-serif;
  min-height: 100vh; overflow-x: hidden;
}
body::before {
  content:''; position:fixed; inset:0;
  background: radial-gradient(ellipse 80% 50% at 20% -10%, var(--glow) 0%, transparent 60%),
              radial-gradient(ellipse 60% 40% at 80% 110%, var(--glow-red) 0%, transparent 60%);
  pointer-events:none; z-index:0;
}
body::after {
  content:''; position:fixed; inset:0;
  background: repeating-linear-gradient(0deg,transparent,transparent 2px,var(--scan) 2px,var(--scan) 4px);
  pointer-events:none; z-index:999;
}

/* ─────────────────────────────────────────────────────── LOADER */
#loader-overlay {
  position:fixed; inset:0; background:var(--bg); z-index:99999;
  display:flex; align-items:center; justify-content:center;
  flex-direction:column; gap:20px; transition:opacity 0.5s;
}
#loader-overlay.hidden { opacity:0; pointer-events:none; }
.loader-title {
  font-family:'Orbitron',sans-serif; font-size:28px; font-weight:900;
  letter-spacing:6px; color:var(--accent2);
  text-shadow:0 0 20px var(--glow); animation:pulse 1.5s ease-in-out infinite;
}
.loader-bar-wrap { width:280px; height:3px; background:var(--border); overflow:hidden; }
.loader-bar { height:100%; background:linear-gradient(90deg,var(--accent),var(--accent2)); animation:loadbar 1.2s ease-in-out infinite; }
.loader-text { font-family:'Share Tech Mono',monospace; font-size:11px; letter-spacing:3px; color:var(--text-dim); text-transform:uppercase; }
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:0.6} }
@keyframes loadbar { 0%{width:0%;margin-left:0} 50%{width:60%;margin-left:20%} 100%{width:0%;margin-left:100%} }

/* ─────────────────────────────────────────────────────── TOP TOOLBAR */
#toolbar {
  position:fixed; top:0; left:0; right:0; z-index:9990;
  display:flex; gap:6px; padding:8px 12px; flex-wrap:wrap;
  background:rgba(0,0,0,0.5); backdrop-filter:blur(10px);
  border-bottom:1px solid var(--border);
}
.tb-btn {
  background:rgba(255,255,255,0.05); border:1px solid var(--border);
  color:var(--text-dim); font-family:'Share Tech Mono',monospace; font-size:10px;
  padding:5px 11px; cursor:pointer; letter-spacing:1.5px; text-transform:uppercase;
  transition:all 0.18s;
  clip-path:polygon(0 0,calc(100% - 5px) 0,100% 5px,100% 100%,5px 100%,0 calc(100% - 5px));
}
.tb-btn:hover, .tb-btn.active { border-color:var(--accent2); color:var(--accent2); background:rgba(0,212,255,0.08); }
.tb-btn.danger { border-color:var(--accent); color:var(--accent); }
.tb-btn.danger:hover { background:rgba(230,57,70,0.15); }

/* ─────────────────────────────────────────────────────── THEME PANEL */
#theme-panel {
  position:fixed; top:46px; right:12px; z-index:9980;
  background:var(--card); border:1px solid var(--border);
  padding:14px; display:none; flex-direction:column; gap:8px; min-width:160px;
  box-shadow:0 8px 32px rgba(0,0,0,0.6);
}
#theme-panel.open { display:flex; }
#theme-panel h4 { font-family:'Orbitron',sans-serif; font-size:10px; letter-spacing:3px; color:var(--accent2); margin-bottom:4px; }
.theme-option {
  display:flex; align-items:center; gap:8px; cursor:pointer;
  font-family:'Share Tech Mono',monospace; font-size:11px; color:var(--text-dim);
  padding:5px 8px; border:1px solid transparent; transition:all 0.15s;
}
.theme-option:hover { border-color:var(--border); color:var(--text); background:rgba(255,255,255,0.03); }
.theme-option.active { border-color:var(--accent2); color:var(--accent2); }
.theme-swatch { width:14px; height:14px; border-radius:50%; border:1px solid rgba(255,255,255,0.2); flex-shrink:0; }

/* ─────────────────────────────────────────────────────── HEADER */
header {
  position:relative; z-index:10;
  padding:72px 40px 20px;
  border-bottom:1px solid var(--border);
  background:linear-gradient(180deg,var(--header-grad) 0%,transparent 100%);
}
.header-inner { max-width:1500px; margin:0 auto; }
.site-title {
  font-family:'Orbitron',sans-serif; font-size:clamp(22px,4vw,42px); font-weight:900;
  letter-spacing:4px; text-transform:uppercase; line-height:1;
  display:flex; align-items:center; gap:16px;
}
.title-mars { color:var(--accent); text-shadow:0 0 20px var(--glow-red),0 0 40px var(--glow-red); }
.title-rest { color:var(--accent2); text-shadow:0 0 20px var(--glow); }
.title-icon {
  width:36px; height:36px;
  background:radial-gradient(circle,var(--accent) 30%,#4a0000 100%);
  border-radius:50%; box-shadow:0 0 20px var(--glow-red),inset 0 -4px 8px rgba(0,0,0,0.4);
  flex-shrink:0; position:relative; overflow:hidden;
}
.title-icon::after {
  content:''; position:absolute; top:20%; left:15%; width:25%; height:15%;
  background:rgba(255,255,255,0.3); border-radius:50%; transform:rotate(-30deg);
}
.header-sub { font-family:'Share Tech Mono',monospace; color:var(--text-dim); font-size:11px; letter-spacing:3px; margin-top:8px; text-transform:uppercase; }

/* ─────────────────────────────────────────────────────── CONTROLS */
.controls {
  position:sticky; top:44px; z-index:100;
  background:rgba(8,11,20,0.93); backdrop-filter:blur(14px);
  border-bottom:1px solid var(--border); padding:14px 40px;
}
.controls-inner { max-width:1500px; margin:0 auto; display:flex; gap:12px; align-items:center; flex-wrap:wrap; }
#search {
  flex:1; min-width:180px;
  background:var(--card); border:1px solid var(--border); color:var(--text);
  font-family:'Share Tech Mono',monospace; font-size:13px; padding:9px 14px; outline:none;
  transition:border-color 0.2s,box-shadow 0.2s;
  clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px));
}
#search::placeholder { color:var(--text-dim); }
#search:focus { border-color:var(--accent2); box-shadow:0 0 0 1px var(--accent2),0 0 12px var(--glow); }
.filter-btns { display:flex; gap:6px; flex-wrap:wrap; }
.filter-btn {
  background:transparent; border:1px solid var(--border); color:var(--text-dim);
  font-family:'Share Tech Mono',monospace; font-size:10px; padding:6px 12px;
  cursor:pointer; letter-spacing:1px; text-transform:uppercase; transition:all 0.18s;
}
.filter-btn:hover,.filter-btn.active { border-color:var(--accent2); color:var(--accent2); background:rgba(0,212,255,0.07); }
.game-count { font-family:'Share Tech Mono',monospace; font-size:11px; color:var(--text-dim); margin-left:auto; white-space:nowrap; }
.game-count span { color:var(--accent2); font-weight:bold; }

/* ─────────────────────────────────────────────────────── MAIN */
main { position:relative; z-index:1; max-width:1500px; margin:0 auto; padding:24px 40px 120px; }
.section-label {
  font-family:'Orbitron',sans-serif; font-size:10px; letter-spacing:4px; text-transform:uppercase;
  color:var(--accent); margin:28px 0 14px; display:flex; align-items:center; gap:12px;
}
.section-label::after { content:''; flex:1; height:1px; background:linear-gradient(90deg,var(--accent),transparent); opacity:0.3; }

/* ─────────────────────────────────────────────────────── GAME GRID */
.game-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(185px,1fr)); gap:10px; }
.game-card {
  position:relative; background:var(--card); border:1px solid var(--border);
  cursor:pointer; transition:all 0.2s ease;
  clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,10px 100%,0 calc(100% - 10px));
  overflow:hidden; display:block; text-decoration:none; color:inherit;
  animation:cardIn 0.3s ease both;
}
.game-card::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg,rgba(0,212,255,0.04) 0%,transparent 60%);
  opacity:0; transition:opacity 0.2s;
}
.game-card:hover { border-color:var(--accent2); background:var(--card-hover); transform:translateY(-2px);
  box-shadow:0 8px 24px rgba(0,0,0,0.4),0 0 0 1px rgba(0,212,255,0.2),0 0 16px var(--glow); }
.game-card:hover::before { opacity:1; }
.card-body { padding:12px 13px 10px; }
.card-name { font-family:'Rajdhani',sans-serif; font-size:12px; font-weight:600; letter-spacing:0.5px; color:var(--text); line-height:1.3; transition:color 0.18s; word-break:break-word; }
.game-card:hover .card-name { color:var(--accent2); }
.card-tag { display:inline-block; margin-top:5px; font-family:'Share Tech Mono',monospace; font-size:9px; letter-spacing:1px; text-transform:uppercase; color:var(--text-dim); background:rgba(255,255,255,0.03); padding:2px 5px; border:1px solid rgba(255,255,255,0.06); }
.card-tooltip {
  position:absolute; bottom:calc(100% + 6px); left:50%; transform:translateX(-50%);
  background:#1a2535; border:1px solid var(--accent2); color:var(--text);
  font-family:'Share Tech Mono',monospace; font-size:10px; padding:7px 11px; white-space:nowrap;
  pointer-events:none; opacity:0; transition:opacity 0.12s; z-index:200;
  box-shadow:0 4px 16px rgba(0,0,0,0.5),0 0 8px var(--glow);
}
.card-tooltip::after { content:''; position:absolute; top:100%; left:50%; transform:translateX(-50%); border:4px solid transparent; border-top-color:var(--accent2); }
.game-card:hover .card-tooltip { opacity:1; }
.tooltip-title { color:var(--accent2); font-weight:bold; display:block; margin-bottom:3px; }
.tooltip-size { color:var(--text-dim); font-size:9px; }
.no-results { display:none; text-align:center; padding:60px 20px; color:var(--text-dim); font-family:'Share Tech Mono',monospace; font-size:13px; letter-spacing:2px; }
.no-results.show { display:block; }
@keyframes cardIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

/* ─────────────────────────────────────────────────────── MUSIC PLAYER */
#music-player {
  position:fixed; bottom:0; left:0; right:0; z-index:9970;
  background:rgba(8,11,20,0.97); backdrop-filter:blur(20px);
  border-top:1px solid var(--border); padding:0;
  transform:translateY(100%); transition:transform 0.35s cubic-bezier(.4,0,.2,1);
}
#music-player.open { transform:translateY(0); }
#music-player.mini { transform:translateY(calc(100% - 50px)); }
.player-bar {
  display:flex; align-items:center; gap:12px; padding:8px 20px; cursor:pointer;
  border-bottom:1px solid var(--border); min-height:50px;
}
.player-bar-info { flex:1; min-width:0; }
.now-playing-label { font-family:'Share Tech Mono',monospace; font-size:9px; letter-spacing:2px; color:var(--text-dim); text-transform:uppercase; }
.now-playing-title { font-family:'Rajdhani',sans-serif; font-size:14px; font-weight:700; color:var(--accent2); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.player-controls { display:flex; align-items:center; gap:10px; padding:12px 20px 14px; flex-wrap:wrap; }
.p-btn {
  background:transparent; border:1px solid var(--border); color:var(--text-dim);
  font-size:14px; width:34px; height:34px; display:flex; align-items:center; justify-content:center;
  cursor:pointer; transition:all 0.15s; font-family:monospace;
}
.p-btn:hover,.p-btn.active { border-color:var(--accent2); color:var(--accent2); }
.p-btn.play-btn { border-color:var(--accent); color:var(--accent); width:40px; height:40px; font-size:16px; }
.p-btn.play-btn:hover { background:rgba(230,57,70,0.15); }
.player-progress { flex:1; display:flex; align-items:center; gap:8px; min-width:120px; }
.progress-bar { flex:1; height:4px; background:var(--border); cursor:pointer; position:relative; }
.progress-fill { height:100%; background:linear-gradient(90deg,var(--accent),var(--accent2)); transition:width 0.5s; width:0%; }
.time-display { font-family:'Share Tech Mono',monospace; font-size:10px; color:var(--text-dim); white-space:nowrap; }
.volume-wrap { display:flex; align-items:center; gap:6px; }
#vol-slider { width:70px; accent-color:var(--accent2); cursor:pointer; }
.track-list { max-height:160px; overflow-y:auto; border-top:1px solid var(--border); }
.track-item {
  display:flex; align-items:center; gap:10px; padding:8px 20px;
  font-family:'Share Tech Mono',monospace; font-size:11px; color:var(--text-dim);
  cursor:pointer; transition:all 0.15s; border-bottom:1px solid rgba(255,255,255,0.03);
}
.track-item:hover { background:rgba(255,255,255,0.03); color:var(--text); }
.track-item.playing { color:var(--accent2); background:rgba(0,212,255,0.05); }
.track-num { color:var(--text-dim); width:20px; text-align:right; font-size:10px; }
.track-name { flex:1; }
.track-dur { color:var(--text-dim); font-size:10px; }
/* vis bars */
.vis-bars { display:flex; gap:2px; align-items:flex-end; height:20px; width:24px; }
.vis-bar { width:3px; background:var(--accent2); border-radius:1px; animation:none; }
.playing .vis-bar { animation:visBounce 0.6s ease-in-out infinite; }
.vis-bar:nth-child(2) { animation-delay:0.1s; }
.vis-bar:nth-child(3) { animation-delay:0.2s; }
@keyframes visBounce { 0%,100%{height:4px}50%{height:18px} }

/* ─────────────────────────────────────────────────────── GAME MODAL */
#game-modal {
  position:fixed; inset:0; z-index:99000; background:rgba(0,0,0,0.95);
  display:none; flex-direction:column;
}
#game-modal.open { display:flex; }
.modal-bar {
  display:flex; align-items:center; gap:12px; padding:8px 16px;
  background:var(--bg2); border-bottom:1px solid var(--border); flex-shrink:0;
}
.modal-title { font-family:'Orbitron',sans-serif; font-size:12px; letter-spacing:2px; color:var(--accent2); flex:1; }
.modal-btn {
  background:transparent; border:1px solid var(--border); color:var(--text-dim);
  font-family:'Share Tech Mono',monospace; font-size:10px; padding:5px 10px;
  cursor:pointer; letter-spacing:1px; transition:all 0.15s;
}
.modal-btn:hover { border-color:var(--accent2); color:var(--accent2); }
.modal-btn.close-btn { border-color:var(--accent); color:var(--accent); }
.modal-btn.close-btn:hover { background:rgba(230,57,70,0.15); }
.modal-content { flex:1; position:relative; overflow:hidden; }
#game-frame { width:100%; height:100%; border:none; background:#000; }
#ruffle-container { width:100%; height:100%; }
#ruffle-container ruffle-player { width:100%; height:100%; }

/* HTML RUNNER */
#html-runner {
  position:fixed; inset:0; z-index:98000; background:var(--bg);
  display:none; flex-direction:column;
}
#html-runner.open { display:flex; }
.runner-bar { display:flex; align-items:center; gap:10px; padding:8px 16px; background:var(--bg2); border-bottom:1px solid var(--border); flex-shrink:0; }
.runner-bar h3 { font-family:'Orbitron',sans-serif; font-size:11px; letter-spacing:2px; color:var(--accent2); flex:1; }
.runner-split { display:flex; flex:1; overflow:hidden; }
#html-editor {
  flex:1; resize:none; background:var(--card); color:var(--text);
  font-family:'Share Tech Mono',monospace; font-size:12px; border:none;
  border-right:1px solid var(--border); padding:14px; outline:none; tab-size:2;
}
#html-preview { flex:1; border:none; background:#fff; }

/* PROXY PANEL */
#proxy-panel {
  position:fixed; inset:0; z-index:97000; background:rgba(0,0,0,0.95);
  display:none; flex-direction:column;
}
#proxy-panel.open { display:flex; }
.proxy-bar { display:flex; align-items:center; gap:10px; padding:8px 16px; background:var(--bg2); border-bottom:1px solid var(--border); flex-shrink:0; }
.proxy-bar h3 { font-family:'Orbitron',sans-serif; font-size:11px; letter-spacing:2px; color:var(--accent2); }
.proxy-tabs { display:flex; gap:6px; margin-left:auto; }
.proxy-tab { background:transparent; border:1px solid var(--border); color:var(--text-dim); font-family:'Share Tech Mono',monospace; font-size:10px; padding:5px 12px; cursor:pointer; letter-spacing:1px; transition:all 0.15s; }
.proxy-tab.active { border-color:var(--accent2); color:var(--accent2); background:rgba(0,212,255,0.08); }
.proxy-content { flex:1; display:none; flex-direction:column; padding:20px; gap:14px; overflow-y:auto; }
.proxy-content.active { display:flex; }
.proxy-url-bar { display:flex; gap:10px; }
#proxy-url { flex:1; background:var(--card); border:1px solid var(--border); color:var(--text); font-family:'Share Tech Mono',monospace; font-size:13px; padding:10px 14px; outline:none; }
#proxy-url:focus { border-color:var(--accent2); }
.proxy-go { background:var(--accent2); border:none; color:#000; font-family:'Orbitron',monospace; font-size:11px; padding:10px 20px; cursor:pointer; font-weight:700; letter-spacing:2px; }
#proxy-frame { flex:1; border:none; background:#fff; min-height:400px; border-radius:2px; }
.proxy-info { font-family:'Share Tech Mono',monospace; font-size:12px; color:var(--text-dim); line-height:1.8; }
.proxy-info a { color:var(--accent2); text-decoration:none; }
.proxy-info a:hover { text-shadow:0 0 8px var(--glow); }

/* FOOTER */
footer { position:relative; z-index:1; border-top:1px solid var(--border); text-align:center; padding:22px 20px; font-family:'Share Tech Mono',monospace; font-size:11px; letter-spacing:2px; color:var(--text-dim); }
footer span { color:var(--accent); }
footer a { color:var(--accent2); text-decoration:none; }

/* RESPONSIVE */
@media(max-width:600px) {
  header,.controls { padding-left:14px; padding-right:14px; }
  main { padding:18px 14px 120px; }
  .game-grid { grid-template-columns:repeat(auto-fill,minmax(145px,1fr)); gap:8px; }
}
#toast.show { opacity:1 !important; }
#settings-panel.open { display:flex !important; }
</style>
</head>
<body data-theme="mars">

<!-- LOADER -->
<div id="loader-overlay">
  <div class="loader-title">MARS GAME STASH</div>
  <div class="loader-bar-wrap"><div class="loader-bar"></div></div>
  <div class="loader-text">Loading game library...</div>
</div>

<!-- TOP TOOLBAR -->
<div id="toolbar">
  <button class="tb-btn danger" onclick="cloakBlank()">⬛ Blank Cloak</button>
