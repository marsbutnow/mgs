  { title:"Boss Battle Theme", src:"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-8.mp3" },
];
let curTrack = 0, isPlaying = false, shuffle = false, loop = false;
const audio = document.getElementById('audio-player');

function initPlayer() {
  const tl = document.getElementById('track-list');
  tl.innerHTML = tracks.map((t,i) => `
    <div class="track-item${i===curTrack?' playing':''}" id="ti-${i}" onclick="playTrack(${i})">
      <span class="track-num">${i+1}</span>
      <div class="vis-bars" style="width:18px;height:16px">
        <div class="vis-bar" style="height:4px"></div>
        <div class="vis-bar" style="height:4px"></div>
        <div class="vis-bar" style="height:4px"></div>
      </div>
      <span class="track-name">${t.title}</span>
    </div>
  `).join('');
  audio.src = tracks[curTrack].src;
  audio.volume = 0.7;
  audio.addEventListener('timeupdate', updateProgress);
  audio.addEventListener('ended', onEnded);
}

function playTrack(i) {
  curTrack = i;
  audio.src = tracks[i].src;
  audio.play(); isPlaying = true;
  document.getElementById('play-btn').textContent = '⏸';
  document.getElementById('np-title').textContent = tracks[i].title;
  document.querySelectorAll('.track-item').forEach((el,j) => {
    el.classList.toggle('playing', j===i);
    const bars = el.querySelectorAll('.vis-bar');
    bars.forEach(b => { b.style.animation = j===i ? '' : 'none'; b.style.height = j===i ? '' : '4px'; });
  });
  document.getElementById('vis-bars').querySelectorAll('.vis-bar').forEach(b => b.style.animation='visBounce 0.6s ease-in-out infinite');
}

function togglePlay() {
  if(isPlaying) { audio.pause(); isPlaying=false; document.getElementById('play-btn').textContent='▶'; document.getElementById('vis-bars').querySelectorAll('.vis-bar').forEach(b=>b.style.animation='none'); }
  else { audio.play(); isPlaying=true; document.getElementById('play-btn').textContent='⏸'; document.getElementById('vis-bars').querySelectorAll('.vis-bar').forEach(b=>b.style.animation='visBounce 0.6s ease-in-out infinite'); }
}

function nextTrack() {
  const n = shuffle ? Math.floor(Math.random()*tracks.length) : (curTrack+1)%tracks.length;
  playTrack(n);
}
function prevTrack() { playTrack((curTrack-1+tracks.length)%tracks.length); }
function toggleShuffle() { shuffle=!shuffle; document.getElementById('shuffle-btn').classList.toggle('active',shuffle); }
function toggleLoop() { loop=!loop; audio.loop=loop; document.getElementById('loop-btn').classList.toggle('active',loop); }
function setVol(v) { audio.volume=v; }

function updateProgress() {
  if(!audio.duration) return;
  const pct = (audio.currentTime/audio.duration)*100;
  document.getElementById('prog-fill').style.width=pct+'%';
  document.getElementById('time-cur').textContent=fmtTime(audio.currentTime);
  document.getElementById('time-dur').textContent=fmtTime(audio.duration);
}
function fmtTime(s) { const m=Math.floor(s/60); return m+':'+(Math.floor(s%60)+'').padStart(2,'0'); }
function seekTo(e) { const bar=document.getElementById('prog-bar'); audio.currentTime=(e.offsetX/bar.offsetWidth)*audio.duration; }
function onEnded() { if(!loop) nextTrack(); }

function toggleMusic() {
  const p = document.getElementById('music-player');
  if(!p.classList.contains('open') && !p.classList.contains('mini')) { p.classList.add('mini'); }
  else p.classList.toggle('open');
}
function toggleMusicExpand() {
  const p = document.getElementById('music-player');
  p.classList.toggle('open');
  p.classList.toggle('mini', !p.classList.contains('open'));
}

